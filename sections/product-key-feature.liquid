{% liquid
  assign bg_color = section.settings.background_color
  assign padding_top = section.settings.padding_top
  assign padding_bottom = section.settings.padding_bottom
  assign padding_top_mobile = section.settings.padding_top_mobile
  assign padding_bottom_mobile = section.settings.padding_bottom_mobile
%}

{% style %}
.product_key_feature_{{ section.id }}{
  background:{{ bg_color }};
  padding-top:{{ padding_top_mobile }}px;
  padding-bottom:{{ padding_bottom_mobile }}px;
}

  @media only screen and (min-width: 769px) {


.product_key_feature_{{ section.id }}{
  padding-top:{{ padding_top }}px;
  padding-bottom:{{ padding_bottom }}px;
  }

  }
{% endstyle %}

<style>

.product_key_feature_wrapper {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 32px 24px;
}

.product_key_feature--block {
  display: flex;
  align-items: center;
  flex-direction: column;
  gap: 16px;
  text-align: center;
}

.product_key_feature--block-icon {
  width: 48px;
  height: 48px
}

.product_key_feature--block-icon img {
  width: 100%;
  max-width: 100%;
  display: flex;
}

.product_key_feature--block-title p {
  color: #FAF7F3;
  font-size: 20px;
  font-style: normal;
  font-weight: 700;
  line-height: normal;
  text-transform: uppercase;
  margin: 0;
  letter-spacing: 0;
}


@media only screen and (min-width: 769px) {

  .product_key_feature_wrapper {
    grid-template-columns: repeat(6, 1fr);
    gap: 32px;
  }

  .product_key_feature--block {
    gap: 24px;
  }

  .product_key_feature--block-icon {
    width: 64px;
    height: 64px
  }

  .product_key_feature--block-title p {
    font-size: 24px;
  }

  .product_key_feature--block-title p br {
    display: none;
  }

  .product_key_feature--block-title p:last-child {
    letter-spacing: -1px;
  }

}
</style>

<section class="product_key_feature_section product_key_feature_{{ section.id }}">
  <div class="wrapper">
    <div class="product_key_feature_wrapper">
      {% for block in section.blocks %}
        <div class="product_key_feature--block" {{ block.shopify_attributes }}>
          {% if block.settings.icon != blank %}
          <div class="product_key_feature--block-icon">
            <img src="{{ block.settings.icon | image_url }}" alt="{{ block.settings.title }}" loading="lazy">
          </div>
          {% endif %}
          {% if block.settings.title != blank %}
          <div class="product_key_feature--block-title">
          {{ block.settings.title }}
          </div>
        {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Product Key Feature",
  "settings": [
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color_background",
      "id": "background_color",
      "label": "Background",
      "default": "linear-gradient(90deg, #79A39E 0%, #49827C 100%)"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding top",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding bottom",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding top mobile",
      "default": 32
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding bottom mobile",
      "default": 32
    }
  ],
  "blocks": [
    {
      "type": "text",
      "name": "Featured",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Select the Icon"
        },
        {
          "type": "richtext",
          "id": "title",
          "label": "Title"
        },
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Key Feature"
    }
  ]
}
{% endschema %}
