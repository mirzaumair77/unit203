{% liquid
  assign padding_top = section.settings.padding_top
  assign padding_bottom = section.settings.padding_bottom
  assign padding_top_mobile = section.settings.padding_top-mobile
  assign padding_bottom_mobile = section.settings.padding_bottom-mobile

  assign background_color = section.settings.background_color
  assign heading_color = section.settings.heading_color
  assign card_background_color = section.settings.card_background_color
  assign image_background_color = section.settings.image_background_color
  assign description_color = section.settings.description_color

  assign heading = section.settings.heading
%}

<style>
.featured-in__{{ section.id }} {
  background: {{ background_color }};
  padding-top: {{ padding_top_mobile }}px;
  padding-bottom: {{ padding_bottom_mobile }}px;
}

.featured-in__{{ section.id }} .featured-in__title h2 {
  color: {{ heading_color }};
}

.featured-in__{{ section.id }} .featured-in__card, .featured-in__{{ section.id }} .featured-in__image--wrapper {
  background-color: {{ card_background_color }};
}

.featured-in__{{ section.id }} .featured-in__image--main {
  background-color: {{ image_background_color }};
}

.featured-in__{{ section.id }} .featured-in__description * {
  color: {{ description_color }};
}

@media only screen and (min-width: 769px) {

  .featured-in__{{ section.id }} {
    padding-top: {{ padding_top }}px;
    padding-bottom: {{ padding_bottom }}px;
  }
}

.featured-in__section .wrapper {
  padding: 0;
}

.featured-in__title h2 {
  font-family: Yanone Kaffeesatz, sans-serif;
  font-size: 36px;
  line-height: 1;
  font-weight: 500;
  text-align: center;
  margin: 0;
}

.featured-in__main {
  padding-top: 75px;
}

.featured-in__card {
  height: auto;
  max-width: calc(85% - 5px);
  width: 100%;
  border-radius: 17px;
  padding: 60px 20px 20px;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  box-sizing: border-box;
}

.featured-in__image--wrapper {
  border-radius: 50%;
  padding: 10px;
  position: absolute;
  top: -60px;
  left: 50%;
  transform: translateX(-50%);
}

.featured-in__image--main {
  position: relative;
  border-radius: 50%;
  padding: 5px;
  width: 100px;
  height: 100px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.featured-in__image img {
  width: 100%;
  height: auto;
  display: flex;
}

.featured-in__image--before, .featured-in__image--after {
  position: absolute;
  bottom: 7px;
}

.featured-in__image--before {
  right: 100%;
}

.featured-in__image--after {
  left: 100%;
}

.featured-in__description p {
  font-family: var(--FONT-STACK-BODY);
  font-size: 14px;
  line-height: 16.8px;
  font-style: italic;
  text-align: center;
  margin: 0;
}

.featured-in__ratings {
  padding-top: 15px;
  display: grid;
  align-items: center;
  justify-content: center;
  grid-auto-flow: column;
  gap: 5px;
}

.featured-in__section .button-next, .featured-in__section .button-prev {
  display: none;
}

@media only screen and (min-width: 769px) {

  .featured-in__section .wrapper {
    padding: 0 var(--gutter-mobile);
  }

  .featured-in__title h2 {
    font-size: 64px;
  }

  .featured-in__main {
    padding-top: 70px;
  }

  .featured-in__card {
    max-width: calc(41% - 5px);
  }

  .featured-in__description p {
    font-size: 18px;
    line-height: 21.6px;
  }

  .featured-in__section .button-next, .featured-in__section .button-prev {
    border: 1px solid #444444;
    border-radius: 50%;
    width: 30px;
    height: 30px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: absolute;
    top: 65%;
    transform: translateY(-65%);
    cursor: pointer;
    z-index: 5;
  }

  .featured-in__section .button-next {
    right: 3px;
  }

  .featured-in__section .button-prev {
    left: 3px;
  }
  
  .featured-in__section .swiper:not(.swiper-initialized) .button-next, .featured-in__section .swiper:not(.swiper-initialized) .button-prev {
    display: none;
  }
  
  .featured-in__section .button-next.swiper-button-disabled, .featured-in__section .button-prev.swiper-button-disabled {
    display: none;
  }
}

@media only screen and (min-width: 1024px) {

  .featured-in__section .wrapper {
    padding: 0 var(--gutter);
  }

  .featured-in__card {
    max-width: calc(25% - 15px / 4);
  }
}
</style>

{% capture star %}
<svg width="13" height="12" viewBox="0 0 13 12" fill="none" xmlns="http://www.w3.org/2000/svg">
  <path d="M5.89758 0.800771C6.14921 0.332035 6.85374 0.332035 7.10537 0.80077L8.58035 3.54836C8.67886 3.73187 8.86372 3.85955 9.07775 3.89191L12.2823 4.37641C12.829 4.45907 13.0467 5.09605 12.6555 5.4684L10.3626 7.65101C10.2094 7.79679 10.1388 8.00338 10.1726 8.20689L10.6781 11.2539C10.7644 11.7737 10.1944 12.1674 9.701 11.9288L6.80889 10.5301C6.61573 10.4367 6.38723 10.4367 6.19406 10.5301L3.30195 11.9288C2.80856 12.1674 2.23858 11.7737 2.32483 11.2539L2.83037 8.20689C2.86414 8.00338 2.79353 7.79679 2.64038 7.65101L0.34741 5.4684C-0.0437689 5.09605 0.173943 4.45907 0.720637 4.37641L3.9252 3.89191C4.13923 3.85955 4.32409 3.73187 4.4226 3.54836L5.89758 0.800771Z" fill="#FFC360"/>
</svg>
{% endcapture %}

<div class="featured-in__section featured-in__{{ section.id }}">
  <div class="wrapper">
    <div class="featured-in__wrapper">
      {% if heading != blank %}
      <div class="featured-in__title">
        <h2>{{ heading }}</h2>
      </div>
      {% endif %}
      <div class="featured-in__main swiper">
        <div class="swiper-wrapper">
          {% for block in section.blocks %}
            {% assign image = block.settings.image %}
            {% assign alt = image.alt | default: 'Featured In' %}
            {% assign description = block.settings.description %}

            <div class="featured-in__card swiper-slide">
              <div class="featured-in__image--wrapper">
                <div class="featured-in__image--main">
                  <div class="featured-in__image--before">
                    <svg class="before" width="13" height="16" viewBox="0 0 13 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path opacity="0.2" d="M6.46723 8.072L10.9672 0.763999L12.9112 1.808L9.67123 8.072L12.9112 14.336L10.9672 15.416L6.46723 8.072ZM0.275234 8.072L4.77523 0.763999L6.71923 1.808L3.47923 8.072L6.71923 14.336L4.77523 15.416L0.275234 8.072Z" fill="#4B4B4B"></path>
                    </svg>
                  </div>
                  <div class="featured-in__image">
                    {{ image
                      | image_url: width: 300
                      | image_tag:
                          alt: alt,
                          loading: "lazy",
                          widths: "180, 240, 300",
                          sizes: "(max-width: 480px) 100vw, 300px"
                    }}
                  </div>
                  <div class="featured-in__image--after">
                    <svg class="after" width="13" height="16" viewBox="0 0 13 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path opacity="0.2" d="M6.53277 8.072L2.03276 0.763999L0.0887651 1.808L3.32877 8.072L0.0887651 14.336L2.03276 15.416L6.53277 8.072ZM12.7248 8.072L8.22477 0.763999L6.28077 1.808L9.52077 8.072L6.28077 14.336L8.22477 15.416L12.7248 8.072Z" fill="#4B4B4B"></path>
                    </svg>
                  </div>
                </div>
              </div>
              {% if description != blank %}
              <div class="featured-in__description">
                {{ description }}
              </div>
              {% endif %}
              <div class="featured-in__ratings">
                {% assign star_rating = block.settings.star_rating %}
                {% for i in (1..star_rating) %}
                  {{ star }}
                {% endfor %}
              </div>
            </div>
          {% endfor %}
        </div>
        <div class="button-prev">
          <svg width="7" height="10" viewBox="0 0 7 10" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M6 1L2 5L6 9" stroke="#444444" stroke-width="1.5"/>
          </svg>
        </div>
        <div class="button-next">
          <svg width="7" height="10" viewBox="0 0 7 10" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M1 1L5 5L1 9" stroke="#444444" stroke-width="1.5"/>
            </svg>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  function initSwiper() {
    try {
      if (typeof Swiper === 'undefined') {
        setTimeout(initSwiper, 100);
        return;
      }
      
      new Swiper('.featured-in__{{ section.id }} .featured-in__main', {
        slidesPerView: 1.2,
        spaceBetween: 10,
        initialSlide: 1,
        centeredSlides: true,
        loop: false,
        navigation: {
          nextEl: '.featured-in__{{ section.id }} .button-next',
          prevEl: '.featured-in__{{ section.id }} .button-prev'
        },
        breakpoints: {
          769: {
            initialSlide: 0,
            centeredSlides: false,
            slidesPerView: 2.5,
            spaceBetween: 5,
          },
          1025: {
            initialSlide: 0,
            centeredSlides: false,
            slidesPerView: 4,
            spaceBetween: 5,
          }
        }
      });
    } catch (error) {
      setTimeout(initSwiper, 100);
    }
  }

  document.addEventListener('DOMContentLoaded', initSwiper);
</script>

{% schema %}
{
  "name": "Featured in",
  "class": "featured--in",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Featured In"
    },
    {
      "type": "header",
      "content": "Section colors"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#3B7865"
    },
    {
      "type": "color_background",
      "id": "background_color",
      "label": "Background Color",
      "default": "linear-gradient(180deg, rgba(249, 239, 218, 1), rgba(234, 206, 160, 1) 56%, rgba(244, 229, 195, 1) 97.122%)"
    },
    {
      "type": "color",
      "id": "card_background_color",
      "label": "Card background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "image_background_color",
      "label": "Image background color",
      "default": "#F5F5F5"
    },
    {
      "type": "color",
      "id": "description_color",
      "label": "Description color",
      "default": "#4B4B4B"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Padding top",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Padding bottom",
      "default": 25
    },
    {
      "type": "range",
      "id": "padding_top-mobile",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Padding top mobile",
      "default": 25
    },
    {
      "type": "range",
      "id": "padding_bottom-mobile",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Padding bottom mobile",
      "default": 25
    }
  ],
  "blocks": [
    {
      "type": "featured",
      "name": "Featured",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "Description"
        },
        {
          "type": "range",
          "id": "star_rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "unit": "px",
          "label": "Star rating",
          "default": 5
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Featured in"
    }
  ]
}
{% endschema %}