      "settings": [
        {
          "type": "image_picker",
          "id": "icon_1",
          "label": "Icon"
        },
        {
          "type": "richtext",
          "id": "text_1",
          "label": "Text"
        },
        {
          "type": "image_picker",
          "id": "icon_2",
          "label": "Icon"
        },
        {
          "type": "richtext",
          "id": "text_2",
          "label": "Text"
        },
        {
          "type": "image_picker",
          "id": "icon_3",
          "label": "Icon"
        },
        {
          "type": "richtext",
          "id": "text_3",
          "label": "Text"
        }
      ]
    },
    {
      "type": "trust-badges",
      "name": "Trust Badges",
      "settings": [
        {
          "type": "image_picker",
          "id": "trust_icon_1",
          "label": "Icon"
        },
        {
          "type": "text",
          "id": "trust_text_1",
          "label": "Text"
        },
        {
          "type": "image_picker",
          "id": "trust_icon_2",
          "label": "Icon"
        },
        {
          "type": "text",
          "id": "trust_text_2",
          "label": "Text"
        },
        {
          "type": "image_picker",
          "id": "trust_icon_3",
          "label": "Icon"
        },
        {
