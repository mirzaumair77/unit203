{% liquid
  assign padding_top = section.settings.padding_top
  assign padding_bottom = section.settings.padding_bottom
  assign padding_top_mobile = section.settings['padding_top-mobile']
  assign padding_bottom_mobile = section.settings['padding_bottom-mobile']

  assign background = section.settings.background_color
  assign subheading = section.settings.subheading
  assign heading = section.settings.heading
  assign description = section.settings.description
  assign button_text = section.settings.button_text
  assign button_url = section.settings.button_url
  assign guarantee_text = section.settings.guarantee_text

  assign divider = section.settings.divider
  assign mobile_divider = section.settings.mobile_divider | default: divider
%}

{% style %}
  .quick-answer__{{ section.id }} {
    background: {{ background }};
    padding-top: {{ padding_top_mobile }}px;
    padding-bottom: {{ padding_bottom_mobile }}px;
  }

  @media only screen and (min-width: 769px) {

    .quick-answer__{{ section.id }} {
      padding-top: {{ padding_top }}px;
      padding-bottom: {{ padding_bottom }}px;
    }
  }

  .section-quick-answer .mobile-hide {
    display: none;
  }

  .quick-answer__divider {
    width: 100%;
  }

  .quick-answer__divider img {
    width: 100%;
    height: 100%;
    display: block;
  }

  .quick-answer .wrapper {
    width: 800px;
  }

  .quick-answer__subheading .section-heading__label-text {
    font-size: 20px;
  }

  .quick-answer__heading.section-heading__title {
    width: 100%;
    max-width: 320px;
    margin: 0 auto;
  }

  .quick-answer__main {
    display: flex;
    flex-direction: column;
    row-gap: 16px;
  }

  .quick-answer__accordion {
    width: 100%;
    background-color: #FAF7F3;
    border-radius: 20px;
    padding: 24px;
  }

  .quick-answer__accordion-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    cursor: pointer;
  }

  .quick-answer__accordion-heading h3 {
    font-family: var(--outfit-font);
    color: #253937;
    font-size: 18px;
    line-height: normal;
    font-weight: 500;
    margin: 0;
  }

  .quick-answer__accordion.active .quick-answer__accordion-heading h3 {
    color: #49827C;
  }

  .quick-answer__accordion-icon {
    width: 100%;
    max-width: 20px;
  }

  .quick-answer__accordion.active .quick-answer__accordion-icon .plus-icon {
    display: none;
  }

  .quick-answer__accordion:not(.active) .quick-answer__accordion-icon .minus-icon {
    display: none;
  }

  .quick-answer__accordion-icon svg {
    width: 100%;
    height: 100%;
    aspect-ratio: 1/1;
    display: block;
  }

  .quick-answer__accordion-text {
    max-height: 0;
    overflow: hidden;
    transition: 0.3s ease;
  }
  
  .quick-answer__accordion.active .quick-answer__accordion-text {
    margin-top: 8px;
  }

  .quick-answer__accordion-text p {
    color: #253937;
    font-size: 16px;
    line-height: 24px;
    font-weight: 400;
    margin: 0;
  }

  .quick-answer__button-main {
    padding-top: 32px;
    margin: 0 auto;
  }
  
  @media only screen and (min-width: 481px) {
    
    .quick-answer__heading.section-heading__title {
      max-width: 100%;
    }
  }

  @media only screen and (min-width: 769px) {
    
    .section-quick-answer .desktop-hide {
      display: none;
    }

    .section-quick-answer .mobile-hide {
      display: block;
    }
    
    .quick-answer__main {
      row-gap: 24px;
    }
    
    .quick-answer__accordion {
      border-radius: 24px;
      padding: 32px;
    }
    
    .quick-answer__accordion-header {
      gap: 16px;
    }
    
    .quick-answer__accordion-heading h3 {
      font-size: 20px;
    }

    .quick-answer__accordion-icon {
      max-width: 24px;
    }
    
    .quick-answer__accordion.active .quick-answer__accordion-text {
      margin-top: 12px;
    }
    
    .quick-answer__accordion-text p {
      font-size: 18px;
      line-height: 27px;
    }
    
    .quick-answer__button-main {
      padding-top: 48px;
    }
  }

{% endstyle %}

{% capture arrow_icon %}
  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 20 20" fill="none">
    <path d="M7.5 4.16675L12.5 10.0001L7.5 15.8334" stroke="#FAF7F3" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>
{% endcapture %}

{% capture check_icon %}
  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 20 20" fill="none">
    <path fill-rule="evenodd" clip-rule="evenodd" d="M10 0.833252C4.93743 0.833252 0.833374 4.93731 0.833374 9.99992C0.833374 15.0625 4.93743 19.1666 10 19.1666C15.0626 19.1666 19.1667 15.0625 19.1667 9.99992C19.1667 4.93731 15.0626 0.833252 10 0.833252ZM14.3393 8.08917C14.6647 7.76374 14.6647 7.2361 14.3393 6.91066C14.0139 6.58523 13.4862 6.58523 13.1608 6.91066L8.75004 11.3214L6.8393 9.41066C6.51386 9.08523 5.98622 9.08523 5.66078 9.41066C5.33535 9.7361 5.33535 10.2637 5.66078 10.5892L8.16078 13.0892C8.48622 13.4146 9.01386 13.4146 9.3393 13.0892L14.3393 8.08917Z" fill="#49827C"/>
  </svg>
{% endcapture %}

{% capture plus_icon %}
  <svg class="plus-icon" width="24" height="25" viewBox="0 0 24 25" fill="none" xmlns="http://www.w3.org/2000/svg">
    <path d="M2 12.5C2 7.78595 2 5.42893 3.46447 3.96447C4.92893 2.5 7.28595 2.5 12 2.5C16.714 2.5 19.0711 2.5 20.5355 3.96447C22 5.42893 22 7.78595 22 12.5C22 17.214 22 19.5711 20.5355 21.0355C19.0711 22.5 16.714 22.5 12 22.5C7.28595 22.5 4.92893 22.5 3.46447 21.0355C2 19.5711 2 17.214 2 12.5Z" fill="#E7F0E4" stroke="#253937" stroke-width="2"></path><path d="M15 12.5L12 12.5M12 12.5L9 12.5M12 12.5L12 9.5M12 12.5L12 15.5" stroke="#253937" stroke-width="2" stroke-linecap="round"></path>
  </svg>
{% endcapture %}

{% capture minus_icon %}
<svg class="minus-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
  <path d="M2 12C2 7.28595 2 4.92893 3.46447 3.46447C4.92893 2 7.28595 2 12 2C16.714 2 19.0711 2 20.5355 3.46447C22 4.92893 22 7.28595 22 12C22 16.714 22 19.0711 20.5355 20.5355C19.0711 22 16.714 22 12 22C7.28595 22 4.92893 22 3.46447 20.5355C2 19.0711 2 16.714 2 12Z" fill="#E7F0E4" stroke="#49827C" stroke-width="2"/>
  <path d="M15 12H9" stroke="#49827C" stroke-width="2" stroke-linecap="round"/>
</svg>
{% endcapture %}

{% if divider != blank or mobile_divider != blank %}
  <div class="quick-answer__divider">
    {{ divider | image_url: width: 2550 | image_tag: alt: divider.alt, class: 'mobile-hide' }}
    {{ mobile_divider | image_url: width: 800 | image_tag: alt: divider.alt, class: 'desktop-hide' }}
  </div>
{% endif %}
<div class="quick-answer quick-answer__{{ section.id }}">
  <div class="wrapper">
    <div class="quick-answer__header section-header__main">
      {% if subheading != blank %}
        <div class="quick-answer__subheading section-heading__label">
          <span class="section-heading__label-text">{{ subheading }}</span>
        </div>
      {% endif %}
      {% if heading != blank %}
        <div class="quick-answer__heading section-heading__title">
          {{ heading }}
        </div>
      {% endif %}
      {% if description != blank %}
        <div class="quick-answer__description section-heading__description">
          {{ description }}
        </div>
      {% endif %}
    </div>
    <div class="quick-answer__main">
      {% for block in section.blocks %}
        {% if block.settings.heading != blank %}
          <div class="quick-answer__accordion">
            <div class="quick-answer__accordion-header">
              <div class="quick-answer__accordion-heading">
                <h3>{{ block.settings.heading }}</h3>
              </div>
              <div class="quick-answer__accordion-icon">
                {{ plus_icon }}
                {{ minus_icon }}
              </div>
            </div>
            {% if block.settings.description != blank %}
              <div class="quick-answer__accordion-text">
                {{ block.settings.description }}
              </div>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>
    {% if button_text != blank or guarantee_text != blank %}
      <div class="quick-answer__button-main button-main">
        {% if button_text != blank %}
          <div class="quick-answer__button">
            <a href="{{ button_url }}" class="button-primary">
              <span class="quick-answer__button-text">{{ button_text }}</span>
              <div class="quick-answer__button-icon button-primary__arrow-icon">{{ arrow_icon }}</div>
            </a>
          </div>
        {% endif %}
        {% if guarantee_text != blank %}
          <div class="quick-answer__guarantee button-primary__guarantee">
            <div class="quick-answer__guarantee-icon">{{ check_icon }}</div>
            <div class="quick-answer__guarantee-text">
              <p>{{ guarantee_text }}</p>
            </div>
          </div>
        {% endif %}
      </div>
    {% endif %}
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function () {
  const accordions = document.querySelectorAll('.quick-answer__accordion');

  accordions.forEach((accordion, index) => {
    const header = accordion.querySelector('.quick-answer__accordion-header');
    const content = accordion.querySelector('.quick-answer__accordion-text');

    header.addEventListener('click', () => {
      accordion.classList.toggle('active');

      if (accordion.classList.contains('active')) {
        content.style.maxHeight = content.scrollHeight + "px";
      } else {
        content.style.maxHeight = null;
      }
    });

    if (index === 0) {
      accordion.classList.add('active');
      content.style.maxHeight = content.scrollHeight + "px";
    }
  });
});
</script>

{% schema %}
{
  "name": "Quick answer",
  "class": "section-quick-answer",
  "tag": "section",
  "settings": [
    {
      "type": "color_background",
      "id": "background_color",
      "label": "Background Color",
      "default": "#E7F0E4"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "TRUE SEA MOSS FAQs"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<h2>Frequently Asked <strong>Questions</strong></h2>"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "TRY SEA MOSS Gummies Today"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button url"
    },
    {
      "type": "text",
      "id": "guarantee_text",
      "label": "Guarantee text",
      "default": "30-Day Money Back Guarantee"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Padding top",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Padding bottom",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_top-mobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Padding top mobile",
      "default": 32
    },
    {
      "type": "range",
      "id": "padding_bottom-mobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Padding bottom mobile",
      "default": 32
    },
    {
      "type": "image_picker",
      "id": "divider",
      "label": "Divider"
    },
    {
      "type": "image_picker",
      "id": "mobile_divider",
      "label": "Mobile divider"
    }
  ],
  "blocks": [
    {
      "type": "accordion",
      "name": "Accordion",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "How much sea moss can I take per day?"
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "Description",
          "default": "<p>For general wellness, 1-2 tablespoons (approx. 15-30g) daily is recommended. Adjust as needed based on personal preference and desired benefits.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Quick answer"
    }
  ]
}
{% endschema %}
