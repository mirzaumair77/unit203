{% liquid
  assign padding_top = section.settings.padding_top
  assign padding_bottom = section.settings.padding_bottom
  assign padding_top_mobile = section.settings.padding_top-mobile
  assign padding_bottom_mobile = section.settings.padding_bottom-mobile

  assign background_color = section.settings.background_color
  assign round_top_corners = section.settings.round_top_corners
  assign round_video_corners = section.settings.round_video_corners
  assign heading_color = section.settings.heading_color
  assign button_background = section.settings.button_background
  assign button_color = section.settings.button_color
  assign button_background_hover = section.settings.button_background-hover
  assign button_color_hover = section.settings.button_color-hover
  
  assign heading = section.settings.heading
  assign button_text = section.settings.button_text
  assign button_url = section.settings.button_url

  assign video_option = section.settings.video_option
  assign video = section.settings.video
  assign video_loop = section.settings.video_loop
  assign video_url = section.settings.video_url

  if video != blank
    assign video_id = video.id
    assign video_alt = video.alt | default: heading
  else
    assign video_id = video_url
    assign video_alt = heading | escape | downcase | replace: ' ', '-'
  endif

  if section.settings.cover_image != blank
    assign poster = section.settings.cover_image
  else
    assign poster = video.preview_image
  endif
%}

<style>

.video-section__{{ section.id }} {
  background: {{ background_color }};
  padding-top: {{ padding_top_mobile }}px;
  padding-bottom: {{ padding_bottom_mobile }}px;
}

{%- if round_top_corners == true -%}
  .video-section__{{ section.id }} {
    margin-top: -20px;
    border-radius: 15px 15px 0 0;
    position: relative;
    z-index: 2;
  }
{%- endif -%}

{%- if round_video_corners == true -%} 
  .video-section__{{ section.id }} .video-section__video--main,
  .video-section__{{ section.id }} .video-section__video--main img, 
  .video-section__{{ section.id }} .video-section__video--main video {
    border-radius: 17px;
  }
{%- endif -%}

.video-section__{{ section.id }} .video-section__heading h2 {
  color: {{ heading_color }}
}

.video-section__{{ section.id }} .video-section__button a {
  background-color: {{ button_background }};
  color: {{ button_color }};
}

.video-section__{{ section.id }} .video-section__button a:hover {
  background-color: {{ button_background_hover }};
  color: {{ button_color_hover }};
}

@media only screen and (min-width: 769px) {

  .video-section__{{ section.id }} {
    padding-top: {{ padding_top }}px;
    padding-bottom: {{ padding_bottom }}px;
  }
}

.video-section__heading {
  width: 100%;
  max-width: 184px;
  margin: 0 auto;
}

.video-section__heading h2 {
  font-family: Yanone Kaffeesatz, sans-serif;
  font-size: 36px;
  line-height: 1;
  font-weight: 500;
  text-align: center;
  margin: 0;
}

.video-section__video--main {
  width: 100%;
  margin-top: 20px;
  display: block;
  overflow: hidden;
  position: relative;
  padding-bottom: var(--ratio-percent, 56.25%);
}

.video-section__poster {
  background: transparent;
  border: none;
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  cursor: pointer;
}

.video-section__poster img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.video-section__video--main video,
.video-section__video--main iframe {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.video-section__poster-button {
  background-color: #ffffff;
  border: 1px solid #ffffff;
  border-radius: 50%;
  width: 32px;
  height: 32px;
  display: flex;
  justify-content: center;
  align-items: center;
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}

.video-section__poster-button svg {
  width: 10px;
}

.video-section__poster-button svg path {
  fill: #444444;
}

.video-section__button {
  max-width: 362px;
  margin: 0 auto;
  padding-top: 20px;
}

.video-section__button a {
  border-radius: 10px;
  min-height: 80px;
  padding: 7px 12px;
  display: flex;
  justify-content: center;
  align-items: center;
  font-family: "Yanone Kaffeesatz", sans-serif;
  font-size: 24px;
  line-height: 1;
  letter-spacing: 1px;
  font-weight: 600;
}

@media only screen and (min-width: 576px) {

  .video-section__heading {
    max-width: 100%;
  }

  .video-section__heading h2 {
    font-size: 64px;
  }

  .video-section__video--main {
    margin-top: 10px;
  }

  .video-section__poster-button {
    background-color: #ffffff3b;
    height: 107px;
    width: 107px;
  }

  .video-section__poster-button svg {
    width: auto;
  }
  
  .video-section__poster-button svg path {
    fill: #FFFFFF;
  }
}

</style>

<div class="video-section video-section__{{ section.id }}">
  <div class="wrapper">
    <div class="video-section__wrpper">
      {%- if heading != blank -%}
      <div class="video-section__heading">
        <h2>{{ heading }}</h2>
      </div>
      {%- endif -%}
      <video-element class="video-section__video--main" {% if poster != null %} style="--ratio-percent: {{ 1 | divided_by: poster.aspect_ratio | times: 100 }}%;"{% endif %}>
        <button
          class="video-section__poster"
          id="video-poster-{{ video_id }}"
          type="button"
          aria-label="{{ video_alt }}"
        >
          {%- if poster != blank -%}
            {{ poster
              | image_url: width: 1200
              | image_tag:
                  alt: video_alt,
                  loading: "lazy",
                  widths: "360, 720, 1080, 1200",
                  sizes: "(max-width: 768px) 100vw, 1200px"
            }}
          {%- endif -%}
          <div class="video-section__poster-button">
            <svg width="29" height="35" viewBox="0 0 29 35" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M28.0125 17.5165L0.316406 0.390625V34.6417L28.0125 17.5165Z" fill="white"/>
            </svg>
          </div>
        </button>

        <template>
        {%- if video_option == "video" -%}
          {{ section.settings.video | video_tag: image_size: '1200x', autoplay: true, loop: video_loop, controls: true, muted: false }}
        {%- else -%}
          {%- if video_url contains "youtube.com" or video_url contains "youtu.be" -%}
            {% assign loop_param = '' %}
            {%- if video_loop -%}
              {% assign loop_param = '&loop=1&playlist=' | append: video_id %}
            {%- endif -%}
            <iframe 
              src="https://www.youtube.com/embed/{{ video_id }}?enablejsapi=1{{ loop_param }}"
              class="js-youtube"
              allow="autoplay; encrypted-media"
              allowfullscreen
              title="{{ heading | escape }}"
            ></iframe>
          {%- elsif video_url contains "vimeo.com" -%}
            {% assign loop_param = '' %}
            {%- if video_loop -%}
              {% assign loop_param = '&loop=1' %}
            {%- endif -%}
            <iframe
              src="https://player.vimeo.com/video/{{ video_id }}?{{ loop_param }}"
              class="js-vimeo"
              allow="autoplay; encrypted-media"
              allowfullscreen
              title="{{ heading | escape }}"
            ></iframe>
          {%- endif -%}
        {%- endif -%}
        </template>
      </video-element>

      {%- if button_url != blank -%}
      <div class="video-section__button">
        <a href="{{ button_url }}">{{ button_text }}</a>
      </div>
      {%- endif -%}
    </div>
  </div>
</div>

<script>
class VideoElement extends HTMLElement {
  constructor() {
    super();
    const poster = this.querySelector('[id^="video-poster-"]');
    if (!poster) return;
    poster.addEventListener('click', this.loadContent.bind(this));
  }
  
  loadContent(focus = true) {
    if (!this.getAttribute('loaded')) {
      this.querySelector('.video-section__poster').style.display = 'none';
      const template = this.querySelector('template');
      if (!template) return;
      
      const clone = template.content.firstElementChild.cloneNode(true);
      this.appendChild(clone);
      this.setAttribute('loaded', true);
      
      if (clone.nodeName === 'VIDEO' && clone.autoplay) {
        clone.play();
      }
      
      if (focus) clone.focus();
    }
  }
}
customElements.define('video-element', VideoElement);
</script>

{% schema %}
{
  "name": "Video Section",
  "class": "video--section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "checkbox",
      "id": "round_video_corners",
      "label": "Round video corners",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "round_top_corners",
      "label": "Round top section corners",
      "default": false
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button url"
    },
    {
      "type": "select",
      "id": "video_option",
      "label": "Video Option",
      "options": [
        {
          "label": "Video",
          "value": "video"
        },
        {
          "label": "Youtube & Vimeo",
          "value": "youtube_vimeo"
        }
      ],
      "default": "video"
    },
    {
      "type": "checkbox",
      "id": "video_loop",
      "label": "Video loop",
      "default": false,
      "visible_if": "{{ section.settings.video_option == 'video' }}"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Video",
      "visible_if": "{{ section.settings.video_option == 'video' }}"
    },
    {
      "type": "video_url",
      "id": "video_url",
      "accept": ["youtube", "vimeo"],
      "label": "Video URL",
      "info": "Youtube or Vimeo",
      "default": "https://www.youtube.com/watch?v=_9VUPq3SxOc",
      "visible_if": "{{ section.settings.video_option == 'youtube_vimeo' }}"
    },
    {
      "type": "image_picker",
      "id": "cover_image",
      "label": "Cover banner"
    },
    {
      "type": "header",
      "content": "Color settings"
    },
    {
      "type": "color_background",
      "id": "background_color",
      "label": "Background color",
      "default": "linear-gradient(180deg, rgba(241, 239, 219, 1), rgba(44, 83, 63, 1) 100%)"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#3B7865"
    },
    {
      "type": "color",
      "id": "button_background",
      "label": "Button background color"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Button color"
    },
    {
      "type": "color",
      "id": "button_background-hover",
      "label": "Button background color hover"
    },
    {
      "type": "color",
      "id": "button_color-hover",
      "label": "Button color hover"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Padding top",
      "default": 35
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Padding bottom",
      "default": 35
    },
    {
      "type": "range",
      "id": "padding_top-mobile",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Padding top mobile",
      "default": 35
    },
    {
      "type": "range",
      "id": "padding_bottom-mobile",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Padding bottom mobile",
      "default": 35
    }
  ],
  "presets": [
    {
      "name": "Video Section"
    }
  ]
}
{% endschema %}