<script>
  document.addEventListener('DOMContentLoaded', function () {
    const tabs = document.querySelectorAll('.subcription_tab');
    const contents = document.querySelectorAll('.subcription_tab_content');

    // default: add .active_plan to the first tab/content if not already
    if (!document.querySelector('.subcription_tab.active_plan')) {
      tabs[0].classList.add('active_plan');
    }
    if (!document.querySelector('.subcription_tab_content.active_plan')) {
      contents[0].classList.add('active_plan');
    }

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const target = tab.dataset.tab;

        // remove active from all tabs and contents
        tabs.forEach((t) => t.classList.remove('active_plan'));
        contents.forEach((c) => c.classList.remove('active_plan'));

        // add active to clicked tab and matching content
        tab.classList.add('active_plan');
        const matchedContent = document.querySelector(`.subcription_tab_content[data-content="${target}"]`);
        if (matchedContent) matchedContent.classList.add('active_plan');
      });
    });
  });
</script>
<script>
document.addEventListener('click', async (e) => {
  const btn = e.target.closest('.subscribe_atc');
  const loading_spinner = document.querySelector('#product-cart-loading');
  

  if (!btn) return;

  // basic guard against double click
  if (btn.dataset.loading === 'true') return;
  btn.dataset.loading = 'true';
  btn.classList.add('is-loading');
  loading_spinner.classList.add('product-cart-loading--loading');

  try {
    const activePlan = document.querySelector('.subcription_tab.active_plan');
    if (!activePlan) throw new Error('No active subscription plan selected.');

    const variantId = activePlan.dataset.variant;
    const sellingPlanId = activePlan.dataset.selling;

    if (!variantId) throw new Error('Variant ID missing on active plan.');

    // Prepare payload
    const payload = { id: Number(variantId), quantity: 1 };
    if (sellingPlanId) payload.selling_plan = Number(sellingPlanId);

    // 1) Add to cart
    const addRes = await fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload),
    });

    if (!addRes.ok) {
      // try to read Shopify error message
      const errBody = await addRes.json().catch(() => null);
      throw new Error(errBody?.description || 'Add to cart failed');
    }

    await addRes.json(); // response about added item (not used further)

    // 2) Get latest cart data (for count, etc.)
    const cartRes = await fetch('/cart.js');
    if (!cartRes.ok) throw new Error('Failed to fetch cart data.');
    const cartData = await cartRes.json();

    // 3) Fetch updated cart drawer section HTML
    const sectionsRes = await fetch('/?sections=cart-drawer');
    if (!sectionsRes.ok) throw new Error('Failed to fetch cart drawer section.');
    const sectionsJson = await sectionsRes.json();

    // find the drawer HTML string in the returned JSON (robust lookup)
    let drawerHtml = sectionsJson['cart-drawer'] ??
                     Object.values(sectionsJson).find(v => typeof v === 'string' && v.includes('cart-drawer'));

    if (!drawerHtml) throw new Error('Cart drawer HTML not found in section response.');

    // parse the HTML and locate the cart-drawer element (or fallback class)
    const parser = new DOMParser();
    const doc = parser.parseFromString(drawerHtml, 'text/html');
    const parsedDrawer = doc.querySelector('cart-drawer') || doc.querySelector('.cart-drawer') || doc.body.firstElementChild;

    if (!parsedDrawer) throw new Error('Parsed cart drawer element not found.');

    // 4) Replace existing drawer or append if it's not on page (fixes "first add" case)
    const existingDrawer = document.querySelector('cart-drawer') || document.querySelector('.cart-drawer');

    if (existingDrawer) {
      existingDrawer.replaceWith(parsedDrawer);
    } else {
      // append near end of body (Dawn places drawer at page end normally)
      document.body.appendChild(parsedDrawer);
    }

    // 5) Update cart count badges (common selectors — adjust if your theme uses a different one)
    const updateCartCount = (count) => {
      const selectors = [
        '.cart-count-bubble',
        '.header__cart-bubble',
        '[data-cart-count]',
        '.header__icon--cart .count',
        '.cart-count'
      ];
      selectors.forEach(sel => {
        const el = document.querySelector(sel);
        if (el) el.textContent = String(count);
      });
    };
    updateCartCount(cartData.item_count ?? 0);

    // 6) Open drawer AFTER it is inserted (and upgraded)
    const drawerEl = document.querySelector('cart-drawer') || document.querySelector('.cart-drawer');
    if (drawerEl && typeof drawerEl.open === 'function') {
      // If it's a custom element with an open() method — call it.
      drawerEl.open();
    } else {
      // fallback: dispatch Dawn-like events so other scripts can react
      document.dispatchEvent(new CustomEvent('cart:refresh', { detail: { cart: cartData }, bubbles: true }));
      document.dispatchEvent(new CustomEvent('cart:updated', { detail: { cart: cartData }, bubbles: true }));
      // last-resort visual fallback (you may need to style this)
      document.body.classList.add('drawer-open');
    }

  } catch (err) {
    console.error('Subscribe add-to-cart error:', err);
    // show friendly error — replace with your toast system if you have one
    if (typeof window.__displayThemeToast === 'function') {
      window.__displayThemeToast(err.message || 'Could not add item to cart');
    } else {
      alert(err.message || 'Could not add item to cart');
    }
  } finally {
    btn.dataset.loading = 'false';
    btn.classList.remove('is-loading');
    loading_spinner.classList.remove('product-cart-loading--loading');
  }
});


</script>
