<style>
     .single_product_{{ section.id }} {
       background: {{ section.settings.background_color }};
       padding-top: {{ section.settings.padding_top_mobile }}px;
       padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
     }

     .single_product_{{ section.id }} .unique_global--button a {
       background-color: {{ section.settings.button_bg_color }};
       color: {{ section.settings.button_text_color }};
     }

     .single_product_{{ section.id }} .unique_global--button a:hover {
       color: {{ section.settings.button_text_hover_color }};
     }

     .single_product_{{ section.id }} .unique_global--button a:before {
       background-color: {{ section.settings.button_bg_hover_color }};
     }

     @media only screen and (min-width: 769px) {
       .single_product_{{ section.id }} {
         padding-top: {{ section.settings.padding_top }}px;
         padding-bottom: {{ section.settings.padding_bottom }}px;
       }
     }

  .single_product_section .hide_mobile {
    display: none;
  }

  .single_product_section .hide_desktop {
    display: block;
    margin-bottom: 10px;
  }

  .single_product_wrapper {
    display: grid;
    grid-template-columns: 1fr;
    gap: 15px;
  }

  .single_product--media-wrapper {
    width: 100%;
    max-width: 660px;
    margin: 0 auto;
    position: relative;
  }

  .single_product--badge {
    position: absolute;
    max-width: 33.3%;
    top: 0;
    z-index: 5;
    right: 58%;
  }

  .single_product--badge img {
    max-width: 100%;
    width: 100%;
  }

  .single_product_media img {
    width: 100%;
    height: auto;
    display: flex;
  }

  .single_product-info-head-title h2 {
    font-family: Yanone Kaffeesatz, sans-serif !important;
    color: #3b7865;
    font-size: 36px;
    line-height: 1;
    font-weight: 500;
    text-align: center;
    margin: 0 0 10px;
  }

  .single_product-info-head-subtitle p {
    font-family: "HarmoniaSansProCyr", sans-serif;
    color: #222;
    font-size: 18px;
    line-height: 1;
    font-weight: 700;
    text-align: center;
    margin: 0 0 15px;
  }

  .single_product-info-bundle {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .single_product-info-bundle-text span {
    display: inline-block;
    border: 1px solid #E5C48D;
    border-radius: 20px;
    font-family: "HarmoniaSansProCyr", sans-serif;
    color: #222;
    font-size: 14px;
    line-height: 21.6px;
    font-weight: 700;
    text-align: center;
  }

  .single_product--bundle-second span {
    padding: 5px 15px 5px 20px;
  }

  .single_product--bundle-first span {
    margin-right: -6px;
    padding: 5px 20px 5px 15px;
  }

  .single_product-info-bundle-content {
    position: relative;
  }

  .single_product-info-bundle-divider {
    border-radius: 50%;
    width: 22px;
    height: 22px;
    position: absolute;
    background-color: #e5c48d;
    right: -13px;
    aspect-ratio: 1 / 1;
    display: flex;
    top: calc(50% - 11px);
    justify-content: center;
    align-items: center;
  }

  @media only screen and (min-width:1025px) {
    .single_product_wrapper {
      grid-template-columns: 50% auto;
      gap: 60px;
    }

    .single_product--media-wrapper {
      max-width: 100%;
    }

    .single_product_wrapper-info {
      max-width: 460px;
      width: 100%;
    }

   .single_product_section .hide_mobile {
      display: block;
    }

   .single_product_section .hide_desktop {
      display: none;
    }

    .single_product-info-head-title h2 {
      text-align: left;
    }

    .single_product-info-head-subtitle p {
      text-align: left;
    }

    .single_product-info-bundle {
      justify-content: left;
    }
  }

  @media only screen and (min-width:769px) {
    .single_product-info-head-title h2 {
      font-size: 64px;
      line-height: 63.49px;
    }

    .single_product-info-head-subtitle p {
      font-size: 22px;
      line-height: 26.4px;
    }

    .single_product-info-bundle-text span {
      font-size: 18px;
    }

    .single_product--badge {
      max-width: 185px;
    }
  }





  {% comment %}subcription widget css {% endcomment %}
   .subcription_tab_row {
