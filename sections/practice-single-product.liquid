{%- liquid
  assign product = section.settings.product
-%}

{%- style -%}
.single-product {
  padding: 80px 16px;
}

.single-product__main {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 48px;
}

.single-product__image img {
  width: 100%;
  height: auto;
  border-radius: 24px;
  object-fit: cover;
  display: block;
}

.single-product__details {
  display: flex;
  flex-direction: column;
  row-gap: 16px;
}

.single-product__title h2 {
  color: #222;
  font-size: 32px;
  line-height: 48px;
  font-weight: 500;
  margin: 0;
}

.single-product__description p {
  color: #222;
  font-size: 16px;
  line-height: 24px;
  font-weight: 400;
  margin: 0;
}

.single-product__price-main {
  display: flex;
  align-items: center;
  gap: 12px;
}

.single-product__price {
  display: block;
  color: #222;
  font-size: 18px;
  line-height: 26px;
  font-weight: 600;
  margin: 0;
}

.single-product__original-price span {
  display: block;
  color: #222;
  font-size: 16px;
  line-height: 24px;
  font-weight: 500;
  margin: 0;
}

.single-product__atc button {
  
}
{%- endstyle -%}

<div class="single-product single-product__{{ section.id }}">
  <div class="wrapper">
    <div class="single-product__main">
      <div class="single-product__image">
        {% render 'product-media-gallery-v2', product: product %}
      </div>
      <div class="single-product__details">
        <div class="single-product__title">
          <h2>{{ product.title }}</h2>
        </div>
        <div class="single-product__description">
          {{ product.description }}
        </div>
        <div class="single-product__price-main">
          {% if product.compare_at_price < product.price %}
            <div class="single-product__price">
              <span>{{ product.price | money_with_currency }}</span>
            </div>
            <div class="single-product__original-price">
              <span>{{ product.compare_at_price | money_with_currency }}</span>
            </div>
          {% else %}
            <div class="single-product__price">
              <span>{{ product.price | money_with_currency }}</span>
            </div>
          {% endif %}
        </div>
        <div class="single-product__atc">
          <button class="button-primary">Add to cart</button>
        </div>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Practice single product",
  "class": "section-practice-single-product",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Product"
    }
  ],
  "blocks": [],
  "presets": [
    {
      "name": "Practice single product"
    }
  ]
}
{% endschema %}
