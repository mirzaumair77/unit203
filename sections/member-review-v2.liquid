<style>
.memeber_review_{{ section.id }}{
  background:{{ section.settings.background_color }};
  padding-top:{{ section.settings.padding_top_mobile }}px;
  padding-bottom:{{ section.settings.padding_bottom_mobile }}px;
}

.memeber_review_{{ section.id }}  .member_review_head--heading h2{
  color:{{ section.settings.heading_color }};
}

.memeber_review_{{ section.id }} .member_review--show_button.unique_global--button a{
  background-color:{{ section.settings.button_bg_color }};
  color:{{ section.settings.button_text_color }};
}

.memeber_review_{{ section.id }} .member_review--show_button.unique_global--button a:hover{
  color:{{ section.settings.button_text_hover_color }};
}

.memeber_review_{{ section.id }} .member_review--show_button.unique_global--button a:before {
  background-color: {{ section.settings.button_bg_hover_color }};
}

.memeber_review_{{ section.id }} .member_review--hide_button.unique_global--button a{
  background-color:{{ section.settings.hide_button_bg_color }};
  color:{{ section.settings.hide_button_text_color }};
}

.memeber_review_{{ section.id }} .member_review--hide_button.unique_global--button a:hover{
  color:{{ section.settings.hide_button_text_hover_color }};
}

.memeber_review_{{ section.id }} .member_review--hide_button.unique_global--button a:before {
  background-color: {{ section.settings.hide_button_bg_hover_color }};
}


@media only screen and (min-width:900px){
  .memeber_review_{{ section.id }}{
    padding-top:{{ section.settings.padding_top }}px;
    padding-bottom:{{ section.settings.padding_bottom }}px;
  }
}

.member_review_section {
  position: relative;
  top: -1px;
}

.memeber_review_head {
  margin-bottom: 40px;
  display: flex;
  align-items: center;
  flex-direction: column;
  gap: 20px;
  text-align: center;
}

.member_review_head--heading {
  max-width: 720px;
}

.member_review_head--heading h2 {
  font-size: 40px;
  line-height: normal;
  font-weight: 800;
  margin: 0;
}

.member_review_head--heading strong {
  text-decoration-line: underline;
  text-decoration-skip-ink: none;
  text-underline-position: from-font;
}

.member_review_section .shopify-app-block .jdgm-prev-badge__text {
  color: #FFFFFF;
  font-size: 16px;
  line-height: normal;
  font-weight: 700;
  margin: 0;
}

span.memeber_review_head--rating-icon {
  display: flex;
}

.member_review_head--total-review-text {
  display: flex;
  align-items: center;
  gap: 10px;
}

.member_review_section .jdgm-preview-badge .jdgm-star.jdgm-star {
  color: #E7721B;
}

.member_review_section .shopify-app-block .jdgm-star.jdgm--on:before {
  width: 16px;
  display: inline-block;
}

.memeber_review_head--rating-text span {
  font-size: 12px;
  line-height: 16.8px;
  font-weight: 400;
  font-family: "HarmoniaSansProCyr", sans-serif;
  margin: 0;
  color: #fff;
}

.member_review_wrapper {
  display: flex;
  justify-content: center;
  flex-wrap: wrap;
  gap: 16px;
}

.member_review_wrapper--block {
  background-color: #fff;
  border-radius: 20px;
  width: 100%;
  height: fit-content;
  padding: 16px;
}

.member_review_wrapper--block-title {
  padding-bottom: 8px;
  border-bottom: 1px solid #4b4b4b3d;
}

.member_review_wrapper--block-title h3 {
  font-family: var(--body-font);
  color: #2c533f;
  font-size: 18px;
  line-height: normal;
  font-weight: 700;
  text-align: center;
  margin: 0;
}

.member_review_wrapper--block-item {
  padding-top: 8px;
  display: flex;
  gap: 8px;
}

.member_review_wrapper--block-item-image {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  flex-shrink: 0;
}

.member_review_wrapper--block-item-image img,
.member_review_wrapper--block-item-image svg {
  width: 100%;
  height: 100%;
  display: flex;
}

.member_review_wrapper--block-content {
  background-color: #f2f1f6;
  border-radius: 16px;
  padding: 10px;
  width: 100%;
}

.member_review_wrapper--block-content-name {
  padding-bottom: 6px;
}

.member_review_wrapper--block-content-name p {
  color: #2c533f;
  font-size: 14px;
  line-height: 16.8px;
  font-weight: 700;
  margin: 0;
}

.member_review_wrapper--block-content-text p {
  color: #222;
  font-size: 10px;
  line-height: 14px;
  font-weight: 400;
  margin: 0;
}

.member_review_wrapper--block-footer-icon>div {
  margin-left: -4px;
  z-index: 2;
}

.member_review_wraper--block-footer {
  padding-top: 6px;
  max-width: calc(100% - 48px);
  margin-left: auto;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.member_review_wrapper--footer-item {
  display: flex;
  flex-wrap: wrap;
}

.member_review_block--footer-icon-like,
.member_review_wrapper--block-footer-icon {
  display: flex;
  align-items: center;
}

.member_review_wraper--block-footer svg {
  display: flex;
}

.member_review_wrapper--footer-item-text {
  display: flex;
}

.member_review_wrapper--footer-item-text span {
  display: inline-block;
  color: #222222;
  font-size: 10px;
  line-height: normal;
  font-weight: 700;
  margin-right: 8px;
}

span.member_review_block--footer-like-text {
  display: inline-block;
  font-size: 8px;
  line-height: 8px;
  font-weight: 400;
  margin-right: 2px;
}

.member_review_buttons {
  padding-top: 30px;
  padding-bottom: 30px;
}

.member_review_section .unique_global--button a {
  max-width: 220px;
  border: 1px solid #ffffff;
  font-family: var(--body-font);
  font-size: 12px;
  line-height: 14px;
  border-radius: 10px;
  letter-spacing: 1px !important;
  padding: 12px 10px;
  min-height: unset;
}

@media only screen and (min-width: 769px) {

  .memeber_review_head {
    margin-bottom: 48px;
    gap: 24px;
  }

  .member_review_head--heading h2 {
    font-size: 48px;
  }

  .member_review_wrapper--block-title {
    padding-bottom: 12px;
    border-bottom: 1.5px solid #4b4b4b3d;
  }

  .member_review_wrapper--block-title h3 {
    font-size: 20px;
  }

  .memeber_review_head--rating-text span {
    font-size: 16px;
    line-height: 22.4px;
  }

  .member_review_wrapper {
    gap: 20px;
  }

  .member_review_wrapper--block {
    border-radius: 24px;
    padding: 20px;
  } 

  .member_review_wrapper--block-item {
    padding-top: 12px;
    gap: 12px;
  }

  .member_review_wrapper--block-item-image {
    width: 40px;
    height: 40px;
  }

  .member_review_wrapper--block-content {
    padding: 12px;
  }

  .member_review_wrapper--block-content-name {
    padding-bottom: 8px;
  }

  .member_review_wrapper--block-content-name p {
    font-size: 16px;
  }

  .member_review_wrapper--block-content-text p {
    font-size: 12px;
  }

  .member_review_wraper--block-footer {
    padding-top: 8px;
    max-width: calc(100% - 52px);
  }

  .member_review_wrapper--footer-item-text span {
    font-size: 12px;
    margin-right: 10px;
  }

  span.member_review_block--footer-like-text {
    font-size: 12px;
    line-height: 12px;
  }

  .member_review_buttons {
    padding-top: 40px;
  }
}

@media only screen and (min-width: 900px) {

  .member_review_wrapper--block {
    width: calc(33.3333% - 15px);
  }
}

@media only screen and (min-width: 1200px) {
  .member_review_wrapper--block {
    width: calc(25% - 15px);
  }
}

@media only screen and (max-width: 768px) {

  .member_review_section .partial-load {
    opacity: 0;
    overflow: hidden;
    border-radius: 10px 10px 0 0;
    position: relative;
    height: 0;
    padding: 0;
  }
}

</style>

<div class="member_review_section memeber_review_{{ section.id }}">
  <div class="wrapper">
    <div class="memeber_review_head">
      {% if section.settings.heading != blank %}
      <div class="member_review_head--heading">
          {{ section.settings.heading | remove: '<p>' | remove: '</p>' }}
      </div>
    {% endif %}
      <div class="member_review_head--total-review-text">
        {% if section.settings.show_reviews_app %}
          {% for block in section.blocks %}
            {% case block.type %}
              {% when '@app' %}
                {% render block %}
            {% endcase %}
          {% endfor %}
        {% else %}
          <span class="memeber_review_head--rating-icon">
            {% for i in (1..5) %}
              {{ star }}
            {% endfor %}
          </span>
          {% if section.settings.total_reviews != blank %}
            <div class="memeber_review_head--rating-text">
              <span>{{ section.settings.total_reviews }}</span>
            </div>
          {% endif %}
        {% endif %}
      </div>
    </div>
    <div class="member_review_wrapper">
      {% for block in section.blocks %}
        {% if block.type == "reviews_item" %}
        <div class="member_review_wrapper--block">
          {% if block.settings.title != blank %}
            <div class="member_review_wrapper--block-title">
              <h3>{{ block.settings.title }}</h3>
            </div>
          {% endif %}
          <div class="member_review_wrapper--block-item">
            <div class="member_review_wrapper--block-item-image">
              {% if block.settings.image != blank %}
                <img src="{{ block.settings.image | image_url: width:100 }}" loading="lazy" alt="{{ block.settings.image.alt }}">
              {% else %}
                <span>
                  {{ image-empty }}
                </span>
              {% endif %}
            </div>
            <div class="member_review_wrapper--block-content">
              {% if block.settings.name != blank %}
                <div class="member_review_wrapper--block-content-name">
                  <p>{{ block.settings.name }}</p>
                </div>
              {% endif %}
              {% if block.settings.content != blank %}
                <div class="member_review_wrapper--block-content-text">
                  {{ block.settings.content }}
                </div>
              {% endif %}
            </div>
          </div>
          <div class="member_review_wraper--block-footer">
            <div class="member_review_wrapper--footer-item">
              {% if block.settings.published_at != blank %}
                <div
                  class="member_review_block--foter-item-published member_review_wrapper--footer-item-text"
                >
                  <span>{{ block.settings.published_at }}</span>
                </div>
              {% endif %}
              {% if block.settings.text_1 != blank %}
                <div class="member_review_block--foter-item-like member_review_wrapper--footer-item-text">
                  <span>{{ block.settings.text_1 }}</span>
                </div>
              {% endif %}
              {% if block.settings.text_2 != blank %}
                <div class="member_review_block--foter-item-reply member_review_wrapper--footer-item-text">
                  <span>{{ block.settings.text_2 }}</span>
                </div>
              {% endif %}
              {% if block.settings.text_3 != blank %}
                <div class="member_review_block--foter-item-message member_review_wrapper--footer-item-text">
                  <span>{{ block.settings.text_3 }}</span>
                </div>
              {% endif %}
            </div>
            <div class="member_review_wrapper--block-footer-icon">
              {% if block.settings.like_count != blank %}
                <div class="member_review_block--footer-icon-like">
                  <span class="member_review_block--footer-like-text">{{ block.settings.like_count }}</span>
                  <span class="member_review_block--footer-icon-like-svg">{{ like }}</span>
                </div>
              {% endif %}
              {% if block.settings.icon_smile == true %}
                <div class="member_review_block--footer-icon-smile-svg">
                  <span>{{ smile }}</span>
                </div>
              {% endif %}
              {% if block.settings.icon_heart == true %}
                <div class="member_review_block--footer-icon-heart-svg">
                  <span>{{ heart }}</span>
                </div>
              {% endif %}
            </div>
          </div>
        </div>
      {% endif %}
      {% endfor %}
    </div>
    {% comment %} <div class="member_review_buttons">
      {% if section.settings.show_button != blank %}
      <div class="member_review--show_button unique_global--button">
        <a href="javascript:void(0);">{{ section.settings.show_button }}</a>
      </div>
      {% endif %}
      {% if section.settings.hide_button != blank %}
        <div class="member_review--hide_button unique_global--button">
          <a href="javascript:void(0);">{{ section.settings.hide_button }}</a>
        </div>
      {% endif %}
    </div> {% endcomment %}
  </div>
</div>

{% comment %} 
<script>
  document.addEventListener('DOMContentLoaded', () => {
    const reviews = document.querySelectorAll('.member_review_wrapper--block'),
          showBtn = document.querySelector('.member_review--show_button'),
          hideBtn = document.querySelector('.member_review--hide_button');

    if (!reviews.length) return;

    let load = window.innerWidth < 768 ? 3 : 4,
        index = load;

    const updateDisplay = (limit) => {
      reviews.forEach((r, i) => {
        r.style.display = i < limit ? 'block' : 'none';
        r.classList.toggle('partial-load', i === Math.min(limit - 1, reviews.length - 1));
      });
      showBtn.style.display = limit < reviews.length ? 'block' : 'none';
      hideBtn.style.display = limit >= reviews.length ? 'block' : 'none';
    };

    const loadMore = () => {
      index += load;
      updateDisplay(index);
    };

    const reset = () => {
      index = load;
      updateDisplay(load);
      document.querySelector('.memeber_review_{{ section.id }}')?.scrollIntoView({ behavior: 'smooth' });
    };

    updateDisplay(load);
    showBtn?.addEventListener('click', loadMore);
    hideBtn?.addEventListener('click', reset);
  });
</script> {% endcomment %}



{% schema %}
{
  "name": "member Review",
  "settings": [
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "checkbox",
      "id": "show_reviews_app",
      "label": "Show app  reviews",
      "default": false
    },
    {
      "type": "text",
      "id": "total_reviews",
      "label": "Total reviews"
    },
    {
      "type": "text",
      "id": "show_button",
      "label": "More Reviews Button Label"
