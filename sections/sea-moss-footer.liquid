{% liquid
  assign padding_top = section.settings.padding_top
  assign padding_bottom = section.settings.padding_bottom
  assign padding_top_mobile = section.settings['padding_top-mobile']
  assign padding_bottom_mobile = section.settings['padding_bottom-mobile']

  assign round_top_corners = section.settings.round_top_corners
  assign background_color = section.settings.background_color
  assign text_color = section.settings.text_color
  assign copyright_color = section.settings.copyright_color

  assign logo = section.settings.logo
  assign show_payment_icons = section.settings.show_payment_icons
  assign copyright_text = section.settings.copyright_text
%}

<style>
  .sea-moss-footer__{{ section.id }} {
    background: {{ background_color }};
    padding-top: {{ padding_top_mobile }}px;
    padding-bottom: {{ padding_bottom_mobile }}px;
  }

  .sea-moss-footer__{{ section.id }} .sea-moss-footer__block--text *,
  .sea-moss-footer__{{ section.id }} .footer__menu-link,
  .sea-moss-footer__{{ section.id }} .sea-moss-footer__block--heading h4,
  .sea-moss-footer__{{ section.id }} .newsletter-form__field-wrapper .field * {
    color: {{ text_color }};
  }

  .sea-moss-footer__{{ section.id }} .sea-moss-footer__copyright--text * {
    color: {{ copyright_color }};
  }

  @media only screen and (min-width: 769px) {

    .sea-moss-footer__{{ section.id }} {
      padding-top: {{ padding_top }}px;
      padding-bottom: {{ padding_bottom }}px;
    }
  }

  @media only screen and (max-width: 768px) {

    {% if round_top_corners == true %}
      .sea-moss-footer__{{ section.id }} {
        border-radius: 15px 15px 0 0;
        margin-top: -20px;
        position: relative;
        z-index: 2;
      }
    {% endif %}
  }

  .sea-moss-footer__logo {
    padding-bottom: 30px;
    width: 100%;
    max-width: 220px;
  }

  .sea-moss-footer__logo img,
  .sea-moss-footer__logo svg {
    width: 100%;
    height: auto;
    display: flex;
  }

  .sea-moss-footer__wrapper {
    display: grid;
    gap: 20px;
  }

  .sea-moss-footer__menu--main {
    width: 100%;
    max-width: 100%;
    display: flex;
    flex-wrap: wrap;
  }

  .sea-moss-footer__menu {
    width: 100%;
    min-width: 140px;
    max-width: calc(50% - 5px);
  }

  .sea-moss-footer__menu ul {
    display: flex;
    flex-direction: column;
    row-gap: 4px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .footer__menu-link {
    font-family: Yanone Kaffeesatz, sans-serif;
    font-size: 20px;
    line-height: 1;
    font-weight: 500;
    text-decoration: none;
  }

  .sea-moss-footer__newsletter--wrapper {
    width: 100%;
    max-width: 290px;
  }

  .sea-moss-footer__newsletter--main {
    padding-top: 20px;
  }

  .newsletter-form__field-wrapper .field::before,
  .newsletter-form__field-wrapper .field::after {
    content: none;
  }

  .newsletter-form__field-wrapper .field__input, .newsletter-form__field-wrapper .field__input:focus-visible {
    background: transparent;
    border: 1px solid;
    border-radius: 20px;
  }
  
  .newsletter-form__field-wrapper .field__input:focus-visible {
    box-shadow: none;
  }

  .newsletter-form__field-wrapper .field__button>.svg-wrapper {
    width: 7px;
  }

  .sea-moss-footer__block--heading h4 {
    font-family: Yanone Kaffeesatz, sans-serif;
    font-size: 20px;
    line-height: 1;
    font-weight: 500;
    margin: 0;
  }

  .sea-moss-footer__block--text {
    padding-top: 7px;
  }

  .sea-moss-footer__block--text * {
    font-family: var(--FONT-STACK-BODY);
    font-size: 14px;
    line-height: 16.8px;
    font-weight: 400;
    margin: 0;
  }

  .sea-moss-footer__bottom--content {
    padding-top: 20px;
    display: grid;
    align-items: flex-start;
    row-gap: 15px;
  }

  .sea-moss-footer__copyright--text * {
    font-family: var(--FONT-STACK-BODY);
    font-size: 14px;
    line-height: 16.8px;
    font-weight: 400;
    margin: 0;
    text-align: center;
  }

  .sea-moss-footer__copyright--text a {
    text-decoration: underline;
  }

  .sea-moss-footer__payments--main ul {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 5px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .sea-moss-footer__payments--main li {
    display: flex;
  }

  .sea-moss-footer__social--wrapper {
    max-width: 100%;
    width: 100%;
    display: flex;
    justify-content: flex-start;
  }

  .sea-moss-footer__social_content--main {
    max-width: 290px;
  }

  .sea-moss-footer__social--main {
    padding-top: 20px;
  }

  .sea-moss-footer__social--main .list-social {
    display: grid;
    grid-template-columns: repeat(6, 36px);
    justify-content: flex-start;
    gap: 14px;
  }

  .sea-moss-footer__social--main .svg-wrapper,
  .sea-moss-footer__social--main .list-social__item .icon {
    width: 100%;
    height: 100%;
  }

  .sea-moss-footer__social--main .list-social__item .icon {
    fill: #FFF;
  }

  .sea-moss-footer__social--main .list-social__link {
    padding: 0;
  }

  @media only screen and (min-width: 769px) {

    .sea-moss-footer__wrapper {
      display: flex;
      flex-wrap: wrap;
    }
    
    .sea-moss-footer__menu {
      max-width: 25%;
    }
  
    .sea-moss-footer__social--wrapper {
      max-width: calc(100% - 310px);
    }

    .sea-moss-footer__social--main .list-social {
      display: flex;
      justify-content: flex-start;
      gap: 14px;
    }

    .sea-moss-footer__social--main .svg-wrapper {
      width: 36px;
      height: 36px;
    }

    .sea-moss-footer__social--main .list-social__item .icon {
      height: 3.6rem;
      width: 3.6rem;
    }

    .sea-moss-footer__bottom--content {
      padding-top: 40px;
      align-items: center;
      justify-items: center;
    }
  }

  @media only screen and (min-width: 990px) {
    
    .sea-moss-footer__wrapper {
      flex-wrap: nowrap;
    }

    .sea-moss-footer__menu--main {
      max-width: 45%;
    }

    .sea-moss-footer__menu {
      max-width: 30.33333%;
    }

    .sea-moss-footer__social--wrapper {
      max-width: calc(55% - 290px);
      justify-content: flex-end;
    }
  }
</style>

<div class="sea-moss-footer sea-moss-footer__{{ section.id }}">
  <div class="wrapper">
    <div class="sea-moss-footer__logo">
      {% if logo != blank %}
        {{ logo | image_url: width: 250 | image_tag: alt: logo.alt | default: shop.name }}
      {% else %}
        <svg width="219" height="35" viewBox="0 0 219 35" fill="none" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink">
          <g clip-path="url(#clip0_3612_2417)">
            <mask id="mask0_3612_2417" style="mask-type:alpha" maskUnits="userSpaceOnUse" x="35" y="6" width="145" height="24">
              <rect x="35.7422" y="6.66663" width="143.94" height="22.6191" fill="url(#pattern0_3612_2417)"/>
            </mask>
          <g mask="url(#mask0_3612_2417)">
            <rect x="33.6914" y="-9.72449" width="143.429" height="57.3717" fill="white"/>
          </g>
          <mask id="mask1_3612_2417" style="mask-type:alpha" maskUnits="userSpaceOnUse" x="-4" y="3" width="36" height="30">
            <rect x="-3.33984" y="3.33325" width="34.9568" height="28.7879" fill="url(#pattern1_3612_2417)"/>
          </mask>
          <g mask="url(#mask1_3612_2417)">
            <rect x="-3.33984" y="3.33325" width="34.9568" height="28.7879" fill="white"/>
            </g>
          </g>
          <defs>
          <pattern id="pattern0_3612_2417" patternContentUnits="objectBoundingBox" width="1" height="1">
            <use xlink:href="#image0_3612_2417" transform="matrix(0.000372958 0 0 0.00237337 0.0142351 -1.42987)"/>
          </pattern>
          <pattern id="pattern1_3612_2417" patternContentUnits="objectBoundingBox" width="1" height="1">
            <use xlink:href="#image0_3612_2417" transform="matrix(0.00153571 0 0 0.00186479 -1.41197 0.019391)"/>
          </pattern>
          <clipPath id="clip0_3612_2417">
            <rect width="218.333" height="35" fill="white"/>
          </clipPath>
            <image id="image0_3612_2417" width="2500" height="995" preserveAspectRatio="none" xlink:href="data:image/png;base64,"/>
          </defs>
        </svg>
      {% endif %}
      </div>
    <div class="sea-moss-footer__wrapper">
      {% for block in section.blocks %}
        {% liquid
          assign menu_1 = block.settings.menu_1
          assign menu_2 = block.settings.menu_2
          assign menu_3 = block.settings.menu_3

          assign subscribe_title = block.settings.subscribe_title
          assign subscribe_text = block.settings.subscribe_text

          assign social_title = block.settings.social_title
          assign social_text = block.settings.social_text
          assign show_social = block.settings.show_social
        %}

        {% case block.type %}
          {% when 'menu' %}
            <div class="sea-moss-footer__menu--main">
              {% if menu_1 != blank %}
                <div class="sea-moss-footer__menu">
                  <ul>
                    {% for link in menu_1.links %}
                      <li class="footer__menu-item">
                        <a href="{{ link.url }}" class="footer__menu-link">{{ link.title }}</a>
                      </li>
                    {% endfor %}
                  </ul>
                </div>
              {% endif %}
              {% if menu_2 != blank %}
                <div class="sea-moss-footer__menu">
                  <ul>
                    {% for link in menu_2.links %}
                      <li class="footer__menu-item">
                        <a href="{{ link.url }}" class="footer__menu-link">{{ link.title }}</a>
                      </li>
                    {% endfor %}
                  </ul>
                </div>
              {% endif %}
              {% if menu_3 != blank %}
                <div class="sea-moss-footer__menu">
                  <ul>
                    {% for link in menu_3.links %}
                      <li class="footer__menu-item">
                        <a href="{{ link.url }}" class="footer__menu-link">{{ link.title }}</a>
                      </li>
                    {% endfor %}
                  </ul>
                </div>
              {% endif %}
            </div>
          {% when 'subscribe' %}
            <div class="sea-moss-footer__newsletter--wrapper">
              <div class="sea-moss-footer__newsletter--content">
                {% if subscribe_title != blank %}
                  <div class="sea-moss-footer__block--heading">
                    <h4>{{ subscribe_title }}</h4>
                  </div>
                {% endif %}
                {% if subscribe_text != blank %}
                  <div class="sea-moss-footer__block--text">
                    {{ subscribe_text }}
                  </div>
                {% endif %}
              </div>
              <div class="sea-moss-footer__newsletter--main">
                {%- form 'customer', id: 'ContactFooter', class: 'footer__newsletter newsletter-form' -%}
                  <input type="hidden" name="contact[tags]" value="newsletter">
                  <div class="newsletter-form__field-wrapper">
                    <div class="field">
                      <input
                        id="NewsletterForm--{{ section.id }}"
                        type="email"
                        name="contact[email]"
                        class="field__input"
                        value="{{ form.email }}"
                        aria-required="true"
                        autocorrect="off"
                        autocapitalize="off"
                        autocomplete="email"
                        {% if form.errors %}
                          autofocus
                          aria-invalid="true"
                          aria-describedby="ContactFooter-error"
                        {% elsif form.posted_successfully? %}
                          aria-describedby="ContactFooter-success"
                        {% endif %}
                        placeholder="{{ 'newsletter.label' | t }}"
                        required
                      >
                      <label class="field__label" for="NewsletterForm--{{ section.id }}">
                        {{ 'newsletter.label' | t }}
                      </label>
                      <button
                        type="submit"
                        class="newsletter-form__button field__button"
                        name="commit"
                        id="Subscribe"
                        aria-label="{{ 'newsletter.button_label' | t }}"
                      >
                        <span class="svg-wrapper">
                          {% comment %} {{- 'icon-arrow.svg' | inline_asset_content -}} {% endcomment %}
                          <svg width="7" height="9" viewBox="0 0 7 9" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M1 1L6 4.5L1 8" stroke="white" stroke-linecap="round"></path>
                          </svg>
                        </span>
                      </button>
                    </div>
                    {%- if form.errors -%}
                      <small class="newsletter-form__message form__message" id="ContactFooter-error">
                        <span class="svg-wrapper">
                          {{- 'icon-error.svg' | inline_asset_content -}}
                        </span>
                        {{- form.errors.translated_fields.email | capitalize }}
                        {{ form.errors.messages.email -}}
                      </small>
                    {%- endif -%}
                  </div>
                  {%- if form.posted_successfully? -%}
                    <h3
                      class="newsletter-form__message newsletter-form__message--success form__message"
                      id="ContactFooter-success"
                      tabindex="-1"
                      autofocus
                    >
                      <span class="svg-wrapper">
                        {{- 'icon-success.svg' | inline_asset_content -}}
                      </span>
                      {{- 'newsletter.success' | t }}
                    </h3>
                  {%- endif -%}
                {%- endform -%}
              </div>
            </div>
          {% when 'social' %}
            <div class="sea-moss-footer__social--wrapper">
              <div class="sea-moss-footer__social_content--main">
                <div class="sea-moss-footer__social--content">
                  {% if social_title != blank %}
                    <div class="sea-moss-footer__block--heading">
                      <h4>{{ social_title }}</h4>
                    </div>
                  {% endif %}
                  {% if social_text != blank %}
                    <div class="sea-moss-footer__block--text">
                      <h4>{{ social_text }}</h4>
                    </div>
                  {% endif %}
                </div>
                {% if show_social == true %}
                  <div class="sea-moss-footer__social--main">
                    {%- render 'social-icons', class: 'footer__list-social' -%}
                  </div>
                {% endif %}
              </div>
            </div>
        {% endcase %}
      {% endfor %}
    </div>
    <div class="sea-moss-footer__bottom--content">
      {% if copyright_text != blank %}
        <div class="sea-moss-footer__copyright--text">
          {{ copyright_text }}
        </div>
      {% endif %}
      {% if show_payment_icons %}
        <div class="sea-moss-footer__payments--main">
          <span class="visually-hidden">{{ 'sections.footer.payment' | t }}</span>
          <ul class="list list-payment" role="list">
            {%- for type in shop.enabled_payment_types -%}
              <li class="list-payment__item">
                {{ type | payment_type_svg_tag: class: 'icon icon--full-color' }}
              </li>
            {%- endfor -%}
          </ul>
        </div>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "checkbox",
      "id": "round_top_corners",
      "label": "Round top corners mobile",
      "default": true
    },
    {
      "type": "header",
      "content": "Footer settings"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "Payment icons",
      "default": true
    },
    {
      "type": "color_background",
      "id": "background_color",
      "label": "Background color",
      "default": "#285234"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Content color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "copyright_color",
      "label": "Copyright color",
      "default": "#A9BAAE"
    },
    {
      "type": "header",
      "content": "Footer padding settings"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Padding top",
      "default": 45
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Padding bottom",
      "default": 45
    },
    {
      "type": "range",
      "id": "padding_top-mobile",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Padding top mobile",
      "default": 45
    },
    {
      "type": "range",
      "id": "padding_bottom-mobile",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Padding bottom mobile",
      "default": 45
    },
    {
      "type": "header",
      "content": "Copyright settings"
    },
    {
      "type": "richtext",
      "id": "copyright_text",
      "label": "Copyright text"
    }
  ],
  "blocks": [
    {
      "type": "menu",
      "name": "Menu",
      "limit": 1,
      "settings": [
        {
          "type": "link_list",
          "id": "menu_1",
          "label": "Menu 3"
        },
        {
          "type": "link_list",
          "id": "menu_2",
          "label": "Menu 2"
        },
        {
          "type": "link_list",
          "id": "menu_3",
          "label": "Menu 3"
        }
      ]
    },
    {
      "type": "subscribe",
      "name": "Subscribe",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "subscribe_title",
          "label": "Subscribe title",
          "default": "Newsletter Subscription"
        },
        {
          "type": "richtext",
          "id": "subscribe_text",
          "label": "Subscribe text",
          "default": "<p>Sign up for our newsletter to receive exclusive offers and updates straight to your inbox</p>"
        }
      ]
    },
    {
      "type": "social",
      "name": "Social",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "social_title",
          "label": "Social title",
          "default": "Our Social"
        },
        {
          "type": "richtext",
          "id": "social_text",
          "label": "Social text",
          "default": "<p>Follow us on social media for updates and promotions</p>"
        },
        {
          "type": "checkbox",
          "id": "show_social",
          "default": true,
          "label": "t:sections.footer.blocks.brand_information.settings.show_social.label",
          "info": "t:sections.footer.blocks.brand_information.settings.show_social.info"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Footer"
    }
  ]
}
{% endschema %}