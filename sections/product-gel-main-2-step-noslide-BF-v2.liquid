{% liquid
  assign image_size = section.settings.image_size
%}

<product-info
  id="MainProduct-{{ section.id }}"
  class="section-{{ section.id }}-padding product--redesign main--{{ template.suffix }}"
  data-section="{{ section.id }}"
  data-product-id="{{ product.id }}"
  data-update-url="true"
  data-url="{{ product.url }}"
>
  {{ 'section-main-gel-v2.css' | asset_url | stylesheet_tag }}

  {%- style -%}
    #shopify-section-{{ section.id }} {
    	background: {{ section.settings.section_background }};
    }

    #shopify-section-{{ section.id }} {
    {% comment %}
      padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    {% endcomment %}
      padding-bottom: 40px;
    }

    @media screen and (min-width: 769px) {
      #shopify-section-{{ section.id }} {
        padding-top: 10px;
      }
    }

    @media screen and (min-width: 1024px) {
      #shopify-section-{{ section.id }} {
        padding-top: {{ section.settings.padding_top }}px;
        padding-bottom: {{ section.settings.padding_bottom }}px;
      }
    }
  {%- endstyle -%}

  <div class="wrapper">
    <div class="product product-gel-step-noslide {% if image_size %} product__wrapper--{{ image_size }}{% endif %}">
      <div class="product__media-wrapper">
        {% render 'product-media-gallery-v2', product: product %}
      </div>
      <div class="product__info-wrapper{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
        <section
          id="ProductInfo-{{ section.id }}"
          class="product__info-container{% if section.settings.enable_sticky_info %} product__column-sticky{% endif %}"
        >
          {%- assign product_form_id = 'product-form-' | append: section.id -%}

          {%- for block in section.blocks -%}
            {%- case block.type -%}
              {%- when '@app' -%}
                {% render block %}
              {%- when 'text' -%}
                <p
                  class="product__text inline-richtext{% if block.settings.text_style == 'uppercase' %} caption-with-letter-spacing{% elsif block.settings.text_style == 'subtitle' %} subtitle{% endif %}"
                  {{ block.shopify_attributes }}
                >
                  {{- block.settings.text -}}
                </p>
              {%- when 'title' -%}
                <div class="product__title" {{ block.shopify_attributes }}>
                  <h1>{{ product.title | escape }}</h1>
                </div>
              {%- when 'price' -%}
                <div id="price-{{ section.id }}" role="status" {{ block.shopify_attributes }}>
                  {%- render 'price',
                    product: product,
                    use_variant: true,
                    show_badges: true,
                    price_class: 'price--large'
                  -%}
                </div>
                {%- if product.quantity_price_breaks_configured? -%}
                  <div class="volume-pricing-note" id="Volume-Note-{{ section.id }}">
                    <span>{{ 'products.product.volume_pricing.note' | t }}</span>
                  </div>
                {%- endif -%}
                {%- if cart.taxes_included or cart.duties_included or shop.shipping_policy.body != blank -%}
                  <div class="product__tax caption rte">
                    {%- if cart.duties_included and cart.taxes_included -%}
                      {{ 'products.product.duties_and_taxes_included' | t }}
                    {%- elsif cart.taxes_included -%}
                      {{ 'products.product.taxes_included' | t }}
                    {%- elsif cart.duties_included -%}
                      {{ 'products.product.duties_included' | t }}
                    {%- endif -%}
                    {%- if shop.shipping_policy.body != blank -%}
                      {{ 'products.product.shipping_policy_html' | t: link: shop.shipping_policy.url }}
                    {%- endif -%}
                  </div>
                {%- endif -%}
                <div {{ block.shopify_attributes }}>
                  {%- assign product_form_installment_id = 'product-form-installment-' | append: section.id -%}
                  {%- form 'product', product, id: product_form_installment_id, class: 'installment caption-large' -%}
                    <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
                    {{ form | payment_terms }}
                  {%- endform -%}
                </div>
                <p
                  class="product__inventory{% if block.settings.text_style == 'uppercase' %} caption-with-letter-spacing{% elsif block.settings.text_style == 'subtitle' %} subtitle{% endif %}{% if product.selected_or_first_available_variant.inventory_management != 'shopify' %} visibility-hidden{% endif %}"
                  {{ block.shopify_attributes }}
                  id="Inventory-{{ section.id }}"
                  role="status"
                >
                  {%- if product.selected_or_first_available_variant.inventory_management == 'shopify' -%}
                    {%- if product.selected_or_first_available_variant.inventory_quantity > 0 -%}
                      {%- if product.selected_or_first_available_variant.inventory_quantity
                          <= block.settings.inventory_threshold
                      -%}
                        <span class="svg-wrapper" style="color: rgb(238, 148, 65)">
                          {{- 'icon-inventory-status.svg' | inline_asset_content -}}
                        </span>
                        {%- if block.settings.show_inventory_quantity -%}
                          {{-
                            'products.product.inventory_low_stock_show_count'
                            | t: quantity: product.selected_or_first_available_variant.inventory_quantity
                          -}}
                        {%- else -%}
                          {{- 'products.product.inventory_low_stock' | t -}}
                        {%- endif -%}
                      {%- else -%}
                        <span class="svg-wrapper" style="color: rgb(62, 214, 96)">
                          {{- 'icon-inventory-status.svg' | inline_asset_content -}}
                        </span>
                        {%- if block.settings.show_inventory_quantity -%}
                          {{-
                            'products.product.inventory_in_stock_show_count'
                            | t: quantity: product.selected_or_first_available_variant.inventory_quantity
                          -}}
                        {%- else -%}
                          {{- 'products.product.inventory_in_stock' | t -}}
                        {%- endif -%}
                      {%- endif -%}
                    {%- else -%}
                      {%- if product.selected_or_first_available_variant.inventory_policy == 'continue' -%}
                        <span class="svg-wrapper" style="color: rgb(62, 214, 96)">
                          {{- 'icon-inventory-status.svg' | inline_asset_content -}}
                        </span>
                        {{- 'products.product.inventory_out_of_stock_continue_selling' | t -}}
                      {%- else -%}
                        <span class="svg-wrapper" style="color: rgb(200, 200, 200)">
                          {{- 'icon-inventory-status.svg' | inline_asset_content -}}
                        </span>
                        {{- 'products.product.inventory_out_of_stock' | t -}}
                      {%- endif -%}
                    {%- endif -%}
                  {%- endif -%}
                </p>
              {%- when 'description' -%}
                {%- if product.description != blank -%}
                  <div class="product__description rte quick-add-hidden" {{ block.shopify_attributes }}>
                    {{ product.description }}
                  </div>
                {%- endif -%}

                <p
                  class="product__sku{% if block.settings.text_style == 'uppercase' %} caption-with-letter-spacing{% elsif block.settings.text_style == 'subtitle' %} subtitle{% endif %}{% if product.selected_or_first_available_variant.sku.size == 0 %} visibility-hidden{% endif %}"
                  id="Sku-{{ section.id }}"
                  role="status"
                  {{ block.shopify_attributes }}
                >
                  <span class="visually-hidden">{{ 'products.product.sku' | t }}:</span>
                  {{- product.selected_or_first_available_variant.sku -}}
                </p>
              {%- when 'custom_liquid' -%}
                {{ block.settings.custom_liquid }}
                {% render 'product-variant-picker', product: product, block: block, product_form_id: product_form_id %}

              {%- when 'collapsible_tab' -%}
                {% if block.settings.heading != blank %}
                  <div class="collapsible-tab__main">
                    <div class="collapsible-tab__heading--main">
                      <div class="collapsible-tab__heading">
                        <h4>{{ block.settings.heading }}</h4>
                      </div>
                      <div class="collapsible-tab__icon">
                        <svg
                          xmlns="http://www.w3.org/2000/svg"
                          class="icon icon-toggle-plus"
                          viewBox="0 0 20 20"
                          fill="none"
                        >
                          <path d="M10.8399 10.8219H16.1761C16.6288 10.8219 17 10.4171 17 9.96441C17 9.51248 16.6288 9.10855 16.1761 9.10855H10.8407V3.82306C10.8407 3.37114 10.4359 3 9.9832 3C9.53045 3 9.1265 3.37114 9.1265 3.82386V9.10695H3.82311C3.37036 9.10695 3 9.51168 3 9.96361C3 10.4163 3.37036 10.8211 3.82311 10.8211H9.1265V16.1761C9.1265 16.6289 9.53045 17 9.9824 17C10.4351 17 10.8399 16.6289 10.8399 16.1761V10.8219Z" fill="#424242"/>
                        </svg>
                        <svg
                          aria-hidden="true"
                          focusable="false"
                          role="presentation"
                          class="icon icon-toggle-minus hidden"
                          viewBox="0 0 19 20"
                        >
                          <path d="M10.725 11.02h6.671c.566 0 1.03-.506 1.03-1.072 0-.565-.464-1.07-1.03-1.07H1.953c-.566 0-1.029.505-1.029 1.07 0 .566.463 1.072 1.029 1.072h8.772z"></path>
                        </svg>
                      </div>
                    </div>
                    {% if block.settings.content != blank %}
                      <div class="collapsible-tab__content--main">
                        {{ block.settings.content }}
                      </div>
                    {% endif %}
                  </div>
                {% endif %}

              {%- when 'buy_buttons' -%}
                {%- render 'buy-buttons',
                  block: block,
                  product: product,
                  product_form_id: product_form_id,
                  section_id: section.id,
                  show_pickup_availability: true
                -%}
                {% render 'icon-with-text', block: block %}

              {%- when 'info_popup' -%}
                <div class="info_popup">
                  {% if block.settings.info_text != blank %}
                    <div class="info_popup__info--text">
                      {{ block.settings.info_text }}
                    </div>
                  {% endif %}
                  {% if block.settings.trigger_text != blank %}
                    <div class="info_popup__trigger--button open-popup-btn">
                      <button type="button">{{ block.settings.trigger_text }}</button>
                    </div>
                  {% endif %}
                </div>

              {%- when 'popup_form' -%}
                {% assign image = block.settings.image %}
                {% assign discount_text = block.settings.discount_text %}
                {% assign popup_button = block.settings.popup_button %}

                <div id="scroll_anchor"></div>
                <div class="popup-form">
                  <div class="popup-form__info">
                    <div class="popup-form__content">
                      <div class="popup-form__heading">
                        <h4>Starting at:</h4>
                      </div>
                      {% assign selected_variant = product.selected_or_first_available_variant %}

                      {%- assign variant_price = selected_variant.price -%}
                      {%- assign variant_compare = selected_variant.compare_at_price -%}
                      {%- assign product_price = product.price -%}
                      {%- assign product_compare = product.compare_at_price_max -%}

                      {% assign image_popup_alt = image.alt | default: product.title %}

                      {%- if variant_compare > variant_price and variant_compare > 0 -%}
                        {%- assign sale_percent = 0 -%}
                        {% assign show_variant_offer = true %}
                      {%- elsif product_compare > product_price and product_compare > 0 -%}
                        {% assign sale_percent = product_compare
                          | minus: product_price
                          | times: 100
                          | divided_by: product_compare
                        %}
                        {% assign show_variant_offer = false %}
                      {%- else -%}
                        {% assign sale_percent = 0 %}
                        {% assign show_variant_offer = false %}
                      {%- endif %}

                      <div class="popup-form__price--main">
                        {% if variant_compare > variant_price and variant_compare > 0 %}
                          <div class="popup-form__price">
                            <span>{{ selected_variant.price | money }}</span>
                          </div>
                          <div class="popup-form__compare--price">
                            <span>{{ selected_variant.compare_at_price | money }}</span>
                          </div>
                        {% else %}
                          <div class="popup-form__price">
                            <span>{{ selected_variant.price | money }}</span>
                          </div>
                        {% endif %}
                      </div>

                      <div class="popup-form__sale--percent">
                        {% if show_variant_offer %}
                          <span>{{ discount_text }}</span>
                        {% elsif sale_percent > 0 %}
                          <span>UP TO {{ sale_percent | round }}% OFF</span>
                        {% endif %}
                      </div>
                    </div>

                    {% if image != blank %}
                      <div class="popup-form__image">
                        {{
                          image
                          | image_url: width: 250
                          | image_tag:
                            alt: image_popup_alt,
                            loading: 'lazy',
                            widths: '150, 200, 250, 300, 400',
                            sizes: '(max-width: 480px) 200px, (max-width: 768px) 250px, 250px'
                        }}
                      </div>
                    {% endif %}
                  </div>
                  {% if popup_button != blank %}
                    <div class="popup-form__popup--button" data-trigger>
                      <span>{{ popup_button }}</span>
                    </div>
                  {% endif %}
                </div>

              {%- when 'gift_banner' -%}
                <style>
                  .block-{{ block.id }}.gift-banner {
                    background-color: {{ block.settings.background_color }};
                    border: 2px solid {{ block.settings.border_color }};
                  }

                  .block-{{ block.id }} .gift-banner__title h4 {
                    color: {{ block.settings.title_color }};
                  }

                  .block-{{ block.id }} .gift-banner__price * {
                    color: {{ block.settings.price_color }};
                  }

                  .block-{{ block.id }} .gift-banner__compare--price * {
                    color: {{ block.settings.compare_price_color }};
                  }

                  .block-{{ block.id }} .gift-banner__subtitle * {
                    color: {{ block.settings.sub_title_color }};
                  }
                </style>

                {% assign image = block.settings.image %}
                {% assign alt = block.settings.image.alt | default: product.title %}
                {% assign title = block.settings.title %}
                {% assign price = block.settings.price %}
                {% assign compare_at_price = block.settings.compare_at_price %}
                {% assign subtitle = block.settings.subtitle %}

                <div class="gift-banner block-{{ block.id }}">
                  {% if image != blank %}
                    <div class="gift-banner__image">
                      {{
                        image
                        | image_url: width: 150
                        | image_tag:
                          alt: alt,
                          loading: 'lazy',
                          widths: '100,150,300',
                          sizes: '(max-width: 480px) 50vw, 150px'
                      }}
                    </div>
                  {% endif %}
                  <div class="gift-banner__content">
                    {% if title != blank %}
                      <div class="gift-banner__title">
                        <h4>{{ title }}</h4>
                      </div>
                    {% endif %}
                    {% if price != blank or compare_at_price != blank %}
                      <div class="gift-banner__price--main">
                        <div class="gift-banner__price">
                          <span>{{ price }}</span>
                        </div>
                        <div class="gift-banner__compare--price">
                          <span>{{ compare_at_price }}</span>
                        </div>
                      </div>
                    {% endif %}
                    {% if subtitle != blank %}
                      <div class="gift-banner__subtitle">
                        {{ subtitle }}
                      </div>
                    {% endif %}
                  </div>
                </div>

              {%- when 'product_tabs' -%}
                {% liquid
                  assign tab_meta_content = product.metafields.custom.tab_section.value

                  if product.metafields.custom.tab_section.value != blank
                    assign tab_1 = product.metafields.custom.tab_section.value.tab_1_name
                    assign tab_2 = product.metafields.custom.tab_section.value.tab_2_name
                    assign tab_3 = product.metafields.custom.tab_section.value.tab_3_name

                    assign content_1 = block.settings.tab_content_1
                    assign content_2 = block.settings.tab_content_2
                    assign content_3 = block.settings.tab_content_3
                  else
                    assign tab_1 = block.settings.tab_1
                    assign tab_2 = block.settings.tab_2
                    assign tab_3 = block.settings.tab_3

                    assign content_1 = block.settings.tab_content_1
                    assign content_2 = block.settings.tab_content_2
                    assign content_3 = block.settings.tab_content_3
                  endif

                  assign tab_icon_alt = item.image.alt | default: product.title
                %}

                <div class="product-tabs">
                  <div class="product-tabs__head--main">
                    {% if tab_1 != blank %}
                      <div class="product_tabs__tab">
                        <span>{{ tab_1 }}</span>
                      </div>
                    {% endif %}
                    {% if tab_2 != blank %}
                      <div class="product_tabs__tab">
                        <span>{{ tab_2 }}</span>
                      </div>
                    {% endif %}
                    {% if tab_3 != blank %}
                      <div class="product_tabs__tab">
                        <span>{{ tab_3 }}</span>
                      </div>
                    {% endif %}
                  </div>
                  {% if block.settings.tab_1_content != blank or tab_meta_content != blank %}
                    <div class="product-tabs__main--content">
                      {% if tab_meta_content != blank %}
                        {% if block.settings.flavours_nutrition_1 %}
                          {% assign meta_content_split = tab_meta_content.tab_1_content | metafield_text | split: 'Texture:' | last %}
                          <div class="whatisit-wrapper">
                            <div class="nutrition-facts-accordion-wrapper {% if block.settings.open_by_default  %}open{% endif %}">
                              <div class="nutrition-facts-accordion-head">
                                <div class="nutrition-facts-accordion-header">
                                  {% if block.settings.title != blank %}
                                    <div class="nutrition-facts-accordion-icon">
                                      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
                                        <path d="M7 12H6C4.11438 12 3.17157 12 2.58579 12.5858C2 13.1716 2 14.1144 2 16V18C2 19.8856 2 20.8284 2.58579 21.4142C3.17157 22 4.11438 22 6 22H8C9.88562 22 10.8284 22 11.4142 21.4142C12 20.8284 12 19.8856 12 18V17" stroke="#253937" stroke-opacity="0.8" stroke-width="1.5"/>
                                        <path d="M12 7H11C9.11438 7 8.17157 7 7.58579 7.58579C7 8.17157 7 9.11438 7 11V13C7 14.8856 7 15.8284 7.58579 16.4142C8.17157 17 9.11438 17 11 17H13C14.8856 17 15.8284 17 16.4142 16.4142C17 15.8284 17 14.8856 17 13V12" stroke="#253937" stroke-opacity="0.8" stroke-width="1.5"/>
                                        <path d="M12 6C12 4.11438 12 3.17157 12.5858 2.58579C13.1716 2 14.1144 2 16 2H18C19.8856 2 20.8284 2 21.4142 2.58579C22 3.17157 22 4.11438 22 6V8C22 9.88562 22 10.8284 21.4142 11.4142C20.8284 12 19.8856 12 18 12H16C14.1144 12 13.1716 12 12.5858 11.4142C12 10.8284 12 9.88562 12 8V6Z" stroke="#253937" stroke-opacity="0.8" stroke-width="1.5"/>
                                      </svg>
                                    </div>
                                  {% endif %}
                                  {% if block.settings.title != blank %}
                                    <div class="nutrition-facts-accordion-title">
                                      <h3>{{ block.settings.title }}</h3>
                                    </div>
                                  {% endif %}
                                </div>
                                {% if block.settings.title != blank %}
                                  <div class="nutrition-facts-accordion_arrow-icon">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
                                      <path d="M5 15L12 9L19 15" stroke="#253937" stroke-opacity="0.8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                                    </svg>
                                  </div>
                                {% endif %}
                              </div>
                              {% if block.settings.description == blank %}{% endif %}
                                <div class="nutrition-facts-accordion-content">
                                  {% assign flavor_products = product.metafields.custom.product_list_for_tastes.value %}
                                  {% for flavor in flavor_products %}
                                    <div class="flavor-product-item">
                                      <div class="flavor-item-card-accordion">
                                        <div class="flavor-item-card-header">
                                          <div class="flavor-product-image">
                                            {% assign flavour_image = flavor.product.metafields.custom.picture_of_a_can | default: flavor.product.featured_image  %}
                                            <img src="{{ flavour_image | image_url: width: 100 }}" loading="lazy" alt="{{ flavor.product.title }} image" width="" height=""/>
                                          </div>
                                          <div class="flavor-product-content">
                                            {% assign flavor_product_title = flavor.product.title | downcase | remove: ' sea moss' %}  
                                            <h3 class="flavor-product-title">{{ flavor_product_title | capitalize }}, Sea Moss Gel</h3>
                                          </div>
                                          <div class="flavor-item-accordion-icon">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
                                              <path d="M5 15L12 9L19 15" stroke="#253937" stroke-opacity="0.8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                                            </svg>
                                          </div>
                                        </div>
                                        
                                          <div class="flavor-product-nutrition-content">
                                            <div class="nutrition-facts-image">
                                              {% if flavor.product.metafields.custom.dawn_nutrition_facts_image != blank %}
                                              {{
                                                flavor.product.metafields.custom.dawn_nutrition_facts_image
                                                | image_url: width: 400
                                                | image_tag:
                                                  alt: flavor.product.metafields.custom.dawn_nutrition_facts_image.alt,
                                                  loading: 'lazy',
                                                  widths: '100, 150, 200, 300, 400'
                                              }}
                                              {% else %}
                                                <img src="{{ 'nutrition_facts_figma_image.png' | file_url }}"
                                                loading="lazy" width="" height="" alt="nutrition facts sample image">
                                              {%endif %}
                                            </div>
                                            <div class="nutritional-ingredients">
                                              <p>
                                                <strong>Ingredients:</strong>
                                                {{ flavor.product.metafields.custom.ingridients
                                                  | metafield_text
                                                  | newline_to_br
                                                  | replace: '<br />', ' '
                                                }}
                                              </p>
                                            </div>
                                          </div>
                                        
                                      </div>
                                      
                                      
                                    </div>
                                  {% endfor %}
                                </div>
                              
                            </div>
                            <div class="nutrition-meta-content">
                              <p>
                                <strong>Texture:</strong><br>
                                {{ meta_content_split }}
                              </p>
                            </div>
                          </div>
                        {% elsif tab_meta_content.tab_1_content != blank %}
                          <div class="product_tabs__content">
                            {{ tab_meta_content.tab_1_content | metafield_tag }}
                          </div>
                        {% elsif tab_meta_content.tab_1_content_list.value != blank %}
                          <div class="product_tabs__icon--content--wrapper">
                            {% for item in tab_meta_content.tab_1_content_list.value %}
                              <div class="product_tabs__icon--content-main">
                                <div class="product_tabs__icon">
                                  {{
                                    item.image
                                    | image_url: width: 65
                                    | image_tag:
                                      alt: tab_icon_alt,
                                      loading: 'lazy',
                                      widths: '32, 48, 65, 96, 128',
                                      sizes: '(max-width: 480px) 48px, (max-width: 768px) 65px, 65px'
                                  }}
                                </div>
                                <div class="product_tabs__content">
                                  {{ item.text | metafield_tag }}
                                </div>
                              </div>
                            {% endfor %}
                          </div>
                        {% endif %}
                      {% elsif content_1 != blank %}
                        <div class="product_tabs__content">
                          {{ content_1 }}
                        </div>
                      {% endif %}
                    </div>
                  {% endif %}
                  {% if block.settings.content_2 != blank or tab_meta_content != blank %}
                    <div class="product-tabs__main--content">
                      {% if tab_2 != blank %}
                        <div class="product_tabs__icon--content--wrapper">
                          <div class="product_tabs__icon--content-main">
                            <div class="product_tabs__icon">
                              <img
                                src="https://cdn.shopify.com/s/files/1/0603/0209/8587/files/energy-production.svg?v=1771842811"
                                width=""
                                height=""
                                alt=""
                              >
                            </div>
                            <div class="product_tabs__content">
                              <p>
                                <strong>Energy Production</strong>: Helps your body make steady, natural energy with
                                essential minerals.
                              </p>
                            </div>
                          </div>
                          <div class="product_tabs__icon--content-main">
                            <div class="product_tabs__icon">
                              <img
                                src="https://cdn.shopify.com/s/files/1/0603/0209/8587/files/immune-support.svg?v=1771842809"
                                width=""
                                height=""
