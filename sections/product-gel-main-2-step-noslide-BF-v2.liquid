{% if section.settings.enable_zoom == true %}
  <script type="module">
    import PhotoSwipeLightbox from 'https://unpkg.com/photoswipe@5/dist/photoswipe-lightbox.esm.min.js';

    document.addEventListener('DOMContentLoaded', () => {
      const lightbox = new PhotoSwipeLightbox({
        gallery: '.product-media__main--images',
        children: 'a.product-single__media-link',
        pswpModule: () => import('https://unpkg.com/photoswipe@5/dist/photoswipe.esm.min.js'),
        zoom: true,
      });

      // ✅ Register UI event before init()
      lightbox.on('uiRegister', () => {
        lightbox.pswp?.on('change', () => {
          document.body.classList.add('pswp-open');

          const closeBtn = document.querySelector('.pswp__button--close');
          if (closeBtn && !closeBtn.dataset.iconChanged) {
            closeBtn.innerHTML = `
            <svg aria-hidden="true" focusable="false" role="presentation" class="icon icon-close" viewBox="0 0 25 25">
              <path d="M11.374 12.167L1.236 22.304a1.09 1.09 0 001.543 1.543L12.917 13.71l10.137 10.138a1.09 1.09 0 001.543-1.543L14.46 12.167 24.597 2.029A1.09 1.09 0 0023.054.486L12.917 10.624 2.779.486A1.09 1.09 0 001.236 2.03l10.138 10.138z"></path>
            </svg>
          `;
            closeBtn.dataset.iconChanged = 'true';
          }
        });

        // Remove class when lightbox closes
        lightbox.pswp?.on('close', () => {
          document.body.classList.remove('pswp-open');
        });
      });

      // ✅ Initialize after event registration
      lightbox.init();
    });
  </script>
{% endif %}

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const scrollButtons = document.querySelectorAll('.scrollable--button');

    if (scrollButtons.length > 0) {
      scrollButtons.forEach((button) => {
        button.addEventListener('click', (e) => {
          e.preventDefault();

          const scrollAnchor = document.querySelector('#scroll_anchor');
          const formProduct = document.querySelector('.popup-form');

          if (scrollAnchor) {
            const scrollPosition = scrollAnchor.getBoundingClientRect().top + window.pageYOffset;

            window.scrollTo({
              top: scrollPosition,
              behavior: 'smooth',
            });
          } else if (formProduct) {
            formProduct.scrollIntoView({ behavior: 'smooth', block: 'start' });
          }
        });
      });
    }
  });
</script>

<script>
  // Product Tabs
  document.addEventListener('DOMContentLoaded', function () {
    const tabButtons = document.querySelectorAll('.product_tabs__tab');
    const tabContents = document.querySelectorAll('.product-tabs__main--content');

    if (!tabButtons.length || !tabContents.length) return;

    // ✅ Default active second tab (index 1)
    tabButtons[1]?.classList.add('active');
    tabContents[1]?.classList.add('active');

    tabButtons.forEach((button, index) => {
      button.addEventListener('click', () => {
        // Remove active classes
        tabButtons.forEach((btn) => btn.classList.remove('active'));
        tabContents.forEach((content) => content.classList.remove('active'));

        // Add active class to clicked tab and its content
        button.classList.add('active');
        tabContents[index].classList.add('active');
      });
    });
  });
</script> 

<script>
  function initnutritionAccordion() {
    const nutritionAccordionItems = document.querySelectorAll('.nutrition-facts-accordion-wrapper');
    if (!nutritionAccordionItems.length) return;

    nutritionAccordionItems.forEach((item) => {
      const nutritionAccordionHeader = item.querySelector('.nutrition-facts-accordion-head');
      const nutritionAccordionContent = item.querySelector('.nutrition-facts-accordion-content');

      if (item.classList.contains('open') && nutritionAccordionContent) {
        nutritionAccordionContent.style.maxHeight = nutritionAccordionContent.scrollHeight + 30 + 'px';
      }

      nutritionAccordionHeader.addEventListener('click', function () {
        const isOpen = item.classList.contains('open');

        if (isOpen) {
          // Close current item
          item.classList.remove('open');
          if (nutritionAccordionContent) nutritionAccordionContent.style.maxHeight = null;
        } else {
          // Open current item (others remain open)
          item.classList.add('open');
          if (nutritionAccordionContent) nutritionAccordionContent.style.maxHeight = nutritionAccordionContent.scrollHeight + 30 + 'px';
        }
      });
    });

    const flavorProductNutrition = document.querySelectorAll('.flavor-item-card-accordion');
    if (!flavorProductNutrition.length) return;

    flavorProductNutrition.forEach((flavorItem) => {
      const nutritionProductHeader = flavorItem.querySelector('.flavor-item-card-header');
      const nutritionProductContent = flavorItem.querySelector('.flavor-product-nutrition-content');

      if (flavorItem.classList.contains('active') && nutritionProductContent) {
        nutritionProductContent.style.maxHeight = nutritionProductContent.scrollHeight + 30 + 'px';
      }

      nutritionProductHeader.addEventListener('click', function () {
        const isOpen = flavorItem.classList.contains('active');

        if (isOpen) {
          // Close current item
          flavorItem.classList.remove('active');
          flavorItem.closest('.flavor-product-item').classList.remove('active');
          if (nutritionProductContent) nutritionProductContent.style.maxHeight = null;
        } else {
          // Open current item (others remain open)
          flavorItem.classList.add('active');
          flavorItem.closest('.flavor-product-item').classList.add('active');
          if (nutritionProductContent) nutritionProductContent.style.maxHeight = nutritionProductContent.scrollHeight + 30 + 'px';
        }
      });
    });

  }

  document.addEventListener('DOMContentLoaded', initnutritionAccordion);
  document.addEventListener('shopify:section:load', initnutritionAccordion);
</script>

