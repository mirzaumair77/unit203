{% liquid
  assign padding_top = section.settings.padding_top
  assign padding_bottom = section.settings.padding_bottom
  assign padding_top_mobile = section.settings['padding_top-mobile']
  assign padding_bottom_mobile = section.settings['padding_bottom-mobile']

  assign background = section.settings.background_color
  assign image_direction = section.settings.image_direction
  assign image = section.settings.image
  assign subheading = section.settings.subheading
  assign heading = section.settings.heading
  assign description = section.settings.description
  assign button_text = section.settings.button_text
  assign button_url = section.settings.button_url
  assign guarantee_text = section.settings.guarantee_text

  assign divider = section.settings.divider
  assign mobile_divider = section.settings.mobile_divider | default: divider
%}

{% style %}
  .product-benefits__{{ section.id }} {
    background: {{ background }};
    padding-top: {{ padding_top_mobile }}px;
    padding-bottom: {{ padding_bottom_mobile }}px;
  }

  @media only screen and (min-width: 769px) {

    .product-benefits__{{ section.id }} {
      padding-top: {{ padding_top }}px;
      padding-bottom: {{ padding_bottom }}px;
    }
  }

  .section-product-benefits-v2 .desktop-hide {
    display: none;
  }

  .product-benefits__divider {
    width: 100%;
  }

  .product-benefits__divider img {
    width: 100%;
    height: auto;
    display: block;
  }

  .product-benefits__main {
    display: flex;
    flex-direction: column-reverse;
    gap: 32px;
  }

  .product-benefits__content-wrapper,
  .product-benefits__image {
    width: 100%;
  }

  .product-benefits__content-wrapper,
  .product-benefits__card-description ul {
    display: flex;
    flex-direction: column;
  }

  .product-benefits__content-wrapper {
    row-gap: 16px;
  }

  .product-benefits__card-description ul {
    row-gap: 12px;
  }

  .product-benefits__card,
  .product-benefits__icon-text-list {
    background-color: #FAF7F3;
    border-radius: 24px;
    padding: 24px;
    display: flex;
  }

  .product-benefits__card {
    flex-wrap: wrap;
    gap: 24px;
  }

  .product-benefits__card-item {
    width: 100%;
    display: flex;
    flex-direction: column;
    row-gap: 16px;
  }

  .product-benefits__card-heading h4,
  .product-benefits__icon-heading h4 {
    font-family: var(--outfit-font);
    color: #253937;
    font-size: 20px;
    line-height: 14px;
    font-weight: 700;
    text-transform: uppercase;
    margin: 0;
  }
  
  .product-benefits__icon-heading br {
    display: none;
  }

  .product-benefits__card-description ul {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .product-benefits__card-description li {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .product-benefits__card-description li::before {
    content: "";
    display: block;
    width: 100%;
    max-width: 20px;
    height: 20px;
    background-image: url(https://cdn.shopify.com/s/files/1/0603/0209/8587/files/Verified_Check.svg?v=1751374113);
    background-repeat: no-repeat;
    background-size: contain;
    background-position: center;
  }

  .product-benefits__card-description li,
  .product-benefits__card-description p {
    color: #253937;
    font-size: 16px;
    line-height: normal;
    font-weight: 400;
  }

  .product-benefits__card-description p {
    line-height: 24px;
    margin: 0;
  }

  .product-benefits__icon-text {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .product-benefits__icon-text-list {
    flex-direction: row;
    align-items: center;
    gap: 32px 16px;
  }

  .product-benefits__icon {
    width: 100%;
    max-width: 48px;
  }
  
  .product-benefits__icon img {
    width: 100%;
    height: 100%;
    aspect-ratio: 1/1;
    display: block;
  }

  .product-benefits__icon-description {
    padding-top: 16px;
  }

  .product-benefits__icon-description p {
    color: #253937;
    font-size: 16px;
    line-height: 24px;
    font-weight: 400;
    margin: 0;
  }

  .product-benefits__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 24px;
    display: block;
  }

  .product-benefits__footer {
    padding-top: 32px;
    margin: 0 auto;
  }

  @media only screen and (min-width: 769px) {

    .section-product-benefits-v2 .mobile-hide {
      display: none;
    }

    .section-product-benefits-v2 .desktop-hide {
      display: block;
    }
    
    .product-benefits__main {
      gap: 48px;
    }

    .product-benefits__content-wrapper {
      row-gap: 24px;
    }

    .product-benefits__card, .product-benefits__icon-text-list {
      border-radius: 32px;
      padding: 32px;
    }

    .product-benefits__card {
      gap: 32px;
    }
    
    .product-benefits__card-item {
      max-width: calc(50% - 16px);
      row-gap: 24px;
    }

    .product-benefits__card-heading h4,
    .product-benefits__icon-heading h4 {
      font-size: 24px;
      line-height: normal;
    }

    .product-benefits__card-description li {
      gap: 8px;
    }

    .product-benefits__card-description li::before {
      max-width: 24px;
      height: 24px;
    }

    .product-benefits__card-description li,
    .product-benefits__card-description p {
      font-size: 18px;
    }
  
    .product-benefits__card-description p {
      line-height: 27px;
    }
    
    .product-benefits__icon-text {
      flex-direction: row;
      gap: 24px;
    }
    
    .product-benefits__icon-text-list {
      align-items: flex-start;
      flex-direction: column;
    }
    
    .product-benefits__icon {
      max-width: 64px;
    }

    .product-benefits__icon-description {
      padding-top: 24px;
    }
    
    .product-benefits__icon-description p {
      font-size: 18px;
      line-height: 27px;
    }

    .product-benefits__image img {
      border-radius: 32px;
    }
    
    .product-benefits__footer {
      padding-top: 48px;
    }
  }

  @media only screen and (min-width: 991px) {

    .product-benefits__main {
      flex-direction: row;
    }
    
    .product-benefits__main.row-reverse {
      flex-direction: row-reverse;
    }

    .product-benefits__content-wrapper,
    .product-benefits__image {
      max-width: 50%;
    }
    
    .product-benefits__icon-heading br {
      display: block;
    }
  }
{% endstyle %}

{% capture arrow_icon %}
  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 20 20" fill="none">
    <path d="M7.5 4.16675L12.5 10.0001L7.5 15.8334" stroke="#FAF7F3" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>
{% endcapture %}

{% capture check_icon %}
  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 20 20" fill="none">
    <path fill-rule="evenodd" clip-rule="evenodd" d="M10 0.833252C4.93743 0.833252 0.833374 4.93731 0.833374 9.99992C0.833374 15.0625 4.93743 19.1666 10 19.1666C15.0626 19.1666 19.1667 15.0625 19.1667 9.99992C19.1667 4.93731 15.0626 0.833252 10 0.833252ZM14.3393 8.08917C14.6647 7.76374 14.6647 7.2361 14.3393 6.91066C14.0139 6.58523 13.4862 6.58523 13.1608 6.91066L8.75004 11.3214L6.8393 9.41066C6.51386 9.08523 5.98622 9.08523 5.66078 9.41066C5.33535 9.7361 5.33535 10.2637 5.66078 10.5892L8.16078 13.0892C8.48622 13.4146 9.01386 13.4146 9.3393 13.0892L14.3393 8.08917Z" fill="#49827C"/>
  </svg>
{% endcapture %}

{% if divider != blank or mobile_divider != blank %}
  <div class="product-benefits__divider">
    {{ divider | image_url: width: 2550 | image_tag: alt: divider.alt, class: 'mobile-hide' }}
    {{ mobile_divider | image_url: width: 800 | image_tag: alt: divider.alt, class: 'desktop-hide' }}
  </div>
{% endif %}
<div class="product-benefits product-benefits__{{ section.id }}">
  <div class="wrapper">
    <div class="product-benefits__header section-header__main">
      {% if subheading != blank %}
        <div class="product-benefits__subheading section-heading__label">
          <span class="section-heading__label-text">{{ subheading }}</span>
        </div>
      {% endif %}
      {% if heading != blank %}
        <div class="product-benefits__heading section-heading__title">
          {{ heading }}
        </div>
      {% endif %}
      {% if description != blank %}
        <div class="product-benefits__description section-heading__description">
          {{ description }}
        </div>
      {% endif %}
    </div>
    <div class="product-benefits__main {{ image_direction }}">
      <div class="product-benefits__content-wrapper">
        <div class="product-benefits__card">
          {% for block in section.blocks %}
            {% if block.type == 'benefits' %}
              {% if block.settings.heading_1 != blank or block.settings.description_1 != blank %}
                <div class="product-benefits__card-item">
                  <div class="product-benefits__card-heading">
                    <h4>{{ block.settings.heading_1 }}</h4>
                  </div>
                  <div class="product-benefits__card-description">
                    {{ block.settings.description_1 }}
                  </div>
                </div>
              {% endif %}
              {% if block.settings.heading_2 != blank or block.settings.description_2 != blank %}
                <div class="product-benefits__card-item">
                  <div class="product-benefits__card-heading">
                    <h4>{{ block.settings.heading_2 }}</h4>
                  </div>
                  <div class="product-benefits__card-description">
                    {{ block.settings.description_2 }}
                  </div>
                </div>
              {% endif %}
            {% endif %}
          {% endfor %}
        </div>
        <div class="product-benefits__icon-text">
          {% for block in section.blocks %}
            {% if block.type == 'icon-with-content' %}
              <div class="product-benefits__icon-text-list">
                {% if block.settings.icon != blank %}
                  <div class="product-benefits__icon">
                    {{ block.settings.icon | image_url: width: 120 | image_tag: alt: block.settings.icon.alt }}
                  </div>
                {% endif %}
                {% if block.settings.heading != blank or block.settings.description != blank %}
                  <div class="product-benefits__icon-content">
                    {% if block.settings.heading != blank %}
                      <div class="product-benefits__icon-heading">
                        <h4>{{ block.settings.heading }}</h4>
                      </div>
                    {% endif %}
                    {% if block.settings.description != blank %}
                      <div class="product-benefits__icon-description">
                        {{ block.settings.description }}
                      </div>
                    {% endif %}
                  </div>
                {% endif %}
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>
      {% if image != blank %}
        <div class="product-benefits__image">
          {{ image | image_url: width: 1200 | image_tag: alt: image.alt }}
        </div>
      {% endif %}
    </div>
    {% if button_text != blank or guarantee_text != blank %}
    <div class="product-benefits__footer button-main">
      {% if button_text != blank %}
      <div class="product-benefits__button button-primary__main">
        <a href="{{ button_url }}" class="button-primary">
          <span class="product-benefits__button-text">{{ button_text }}</span>
          <div class="product-benefits__button-icon button-primary__arrow-icon">{{ arrow_icon }}</div>
        </a>
      </div>
      {% endif %}
      {% if guarantee_text != blank %}
      <div class="product-benefits__guarantee button-primary__guarantee">
        <div class="product-benefits__guarantee-icon">{{ check_icon }}</div>
        <div class="product-benefits__guarantee-text">
          <p>{{ guarantee_text }}</p>
        </div>
      </div>
      {% endif %}
    </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Product benefits v2",
  "class": "section-product-benefits-v2",
  "tag": "section",
  "settings": [
    {
      "type": "color_background",
      "id": "background_color",
      "label": "Background Color",
      "default": "#E7F0E4"
    },
    {
      "type": "select",
      "id": "image_direction",
      "label": "Image direction",
      "options": [
        {
          "value": "row-reverse",
          "label": "Left"
        },
        {
          "value": "row",
          "label": "Right"
        }
      ],
      "default": "row"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "immunity  |  gut health  |  energy"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<p>Take A Healthier <strong>Step Forward</strong></p>"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Our nutritious Sea Moss Gummies will help sharpen your mind and fuel your natural drive - without the crash or sugar fog.</p>"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "TRY SEA MOSS Gummies Today"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button url"
    },
    {
      "type": "text",
      "id": "guarantee_text",
      "label": "Guarantee text",
      "default": "30-Day Money Back Guarantee"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Padding top",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Padding bottom",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_top-mobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Padding top mobile",
      "default": 32
    },
    {
      "type": "range",
      "id": "padding_bottom-mobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Padding bottom mobile",
      "default": 32
    },
    {
      "type": "image_picker",
      "id": "divider",
      "label": "Divider"
    },
    {
      "type": "image_picker",
      "id": "mobile_divider",
      "label": "Mobile divider"
    }
  ],
  "blocks": [
    {
      "type": "benefits",
      "name": "Benefits",
      "settings": [
        {
          "type": "text",
          "id": "heading_1",
          "label": "Heading"
        },
        {
          "type": "richtext",
          "id": "description_1",
          "label": "Benefits"
        },
        {
          "type": "text",
          "id": "heading_2",
          "label": "Heading"
        },
        {
          "type": "richtext",
          "id": "description_2",
          "label": "Description"
        }
      ]
    },
    {
      "type": "icon-with-content",
      "name": "Icon & Content",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "Description"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product benefits v2"
    }
  ]
}
{% endschema %}
