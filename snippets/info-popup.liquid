<div class="info_popup__wrapper" id="popup">
  <div class="info_popup__main">
    <div class="info_popup__close--button" id="closePopupBtn">
      <svg xmlns="http://www.w3.org/2000/svg" width="44" height="44" viewBox="0 0 1024 920" class="icon">
        <path fill="#444" d="M481.83 448l-198.248 198.248c-8.331 8.331-8.331 21.839 0 30.17s21.839 8.331 30.17 0l198.248-198.248 198.248 198.248c8.331 8.331 21.839 8.331 30.17 0s8.331-21.839 0-30.17l-198.248-198.248 198.248-198.248c8.331-8.331 8.331-21.839 0-30.17s-21.839-8.331-30.17 0l-198.248 198.248-198.248-198.248c-8.331-8.331-21.839-8.331-30.17 0s-8.331 21.839 0 30.17l198.248 198.248z"></path>
      </svg>
    </div>
    {% for block in section.blocks %}
      {% assign popup_image = block.settings.popup_image %}
      {% assign popup_text = block.settings.popup_text %}

      {% if popup_image != blank or popup_text != blank %}
        <div class="info_popup__content">
          {% if popup_image != blank %}
            <div class="info__popup__image">
              {{ popup_image | image_url: width: 600 | image_tag: popup_image.alt }}
            </div>
          {% endif %}
          {% if popup_text != blank %}
            <div class="info__popup__text">
              {{ popup_text }}
            </div>
          {% endif %}
        </div>
      {% endif %}
    {% endfor %}
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const popup = document.getElementById('popup');
    const closeBtn = document.getElementById('closePopupBtn');
    const body = document.body;

    const trigger = document.querySelector('.open-popup-btn'); 

    if (trigger) {
      trigger.addEventListener('click', () => {
        popup.classList.add('open-popup');
        body.classList.add('overflow-hidden');
      });
    }

    if (closeBtn) {
      closeBtn.addEventListener('click', () => {
        popup.classList.remove('open-popup');
        body.classList.remove('overflow-hidden');
      });
    }
  });
</script>